{"ast":null,"code":"import AppHeader from '@/components/common/AppHeader.vue';\nimport AppFooter from '@/components/common/AppFooter.vue';\nimport { mapState, mapActions } from 'vuex';\nexport default {\n  name: 'SellProduct',\n  components: {\n    AppHeader,\n    AppFooter\n  },\n  data() {\n    return {\n      product: {\n        name: '',\n        price: '',\n        stock: 1,\n        category: '',\n        description: ''\n      },\n      previewImages: [],\n      emailVerificationError: false,\n      categories: [{\n        id: 'BOOKS',\n        name: '교재/서적'\n      }, {\n        id: 'ELECTRONICS',\n        name: '전자기기'\n      }, {\n        id: 'FASHION',\n        name: '의류/패션'\n      }, {\n        id: 'BEAUTY',\n        name: '화장품/미용'\n      }, {\n        id: 'SPORTS',\n        name: '스포츠/레저'\n      }, {\n        id: 'HOUSEHOLD',\n        name: '생활용품'\n      }, {\n        id: 'HOBBY',\n        name: '취미/게임'\n      }, {\n        id: 'OTHERS',\n        name: '기타'\n      }]\n    };\n  },\n  computed: {\n    ...mapState('products', ['loading']),\n    ...mapState('auth', ['isAuthenticated', 'user'])\n  },\n  created() {\n    if (!this.isAuthenticated) {\n      this.$router.push({\n        name: 'Login',\n        query: {\n          redirect: this.$route.fullPath\n        }\n      });\n      return;\n    }\n\n    // 이메일 인증 완료 여부 확인\n    if (this.$route.query.emailVerified === 'true') {\n      this.emailVerificationError = false;\n    }\n    // 이미 이메일 인증 오류가 있으면 표시\n    else if (this.$route.query.emailError === 'true') {\n      this.emailVerificationError = true;\n    }\n  },\n  methods: {\n    ...mapActions('products', ['createProduct']),\n    handleImageUpload(event) {\n      const files = event.target.files;\n      if (files.length === 0) return;\n\n      // 최대 5개까지만 업로드 가능\n      const remainingSlots = 5 - this.previewImages.length;\n      const selectedFiles = Array.from(files).slice(0, remainingSlots);\n      selectedFiles.forEach(file => {\n        // 파일 유효성 검사 (이미지 파일만)\n        if (!file.type.startsWith('image/')) {\n          alert('이미지 파일만 업로드 가능합니다.');\n          return;\n        }\n\n        // 미리보기 생성\n        const reader = new FileReader();\n        reader.onload = e => {\n          this.previewImages.push({\n            file,\n            preview: e.target.result\n          });\n        };\n        reader.readAsDataURL(file);\n      });\n\n      // 파일 입력 초기화\n      event.target.value = null;\n    },\n    removeImage(index) {\n      this.previewImages.splice(index, 1);\n    },\n    async submitProduct() {\n      try {\n        // FormData 객체 생성\n        const productData = {\n          name: this.product.name,\n          price: Number(this.product.price),\n          stock: Number(this.product.stock),\n          category: this.product.category,\n          status: 'ACTIVE',\n          description: this.product.description,\n          sellerName: this.user?.name || this.user?.username || ''\n        };\n\n        // 이미지 파일 추출\n        const images = this.previewImages.map(item => item.file);\n        const response = await this.createProduct({\n          productData,\n          images\n        });\n\n        // 성공 시 상품 상세 페이지로 이동\n        this.$router.push({\n          name: 'ProductDetail',\n          params: {\n            id: response.product.id\n          }\n        });\n      } catch (error) {\n        console.error('상품 등록 오류:', error);\n\n        // 학교 이메일 인증 오류인 경우\n        if (error.message && error.message.includes('학교 이메일 인증이 필요합니다')) {\n          this.emailVerificationError = true;\n        } else {\n          alert('상품 등록 중 오류가 발생했습니다. 다시 시도해주세요.');\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppHeader","AppFooter","mapState","mapActions","name","components","data","product","price","stock","category","description","previewImages","emailVerificationError","categories","id","computed","created","isAuthenticated","$router","push","query","redirect","$route","fullPath","emailVerified","emailError","methods","handleImageUpload","event","files","target","length","remainingSlots","selectedFiles","Array","from","slice","forEach","file","type","startsWith","alert","reader","FileReader","onload","e","preview","result","readAsDataURL","value","removeImage","index","splice","submitProduct","productData","Number","status","sellerName","user","username","images","map","item","response","createProduct","params","error","console","message","includes"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\views\\SellProduct.vue"],"sourcesContent":["<template>\r\n  <div class=\"min-h-screen bg-gray-50\">\r\n    <AppHeader />\r\n    \r\n    <main class=\"py-8\">\r\n      <div class=\"container mx-auto px-4 max-w-3xl\">\r\n        <h1 class=\"text-2xl font-bold mb-6\">상품 등록</h1>\r\n        \r\n        <!-- 이메일 인증 오류 안내 -->\r\n        <div v-if=\"emailVerificationError\" class=\"mb-6 bg-yellow-100 border-l-4 border-yellow-500 p-4 rounded\">\r\n          <div class=\"flex items-start\">\r\n            <div class=\"flex-shrink-0\">\r\n              <i class=\"fas fa-exclamation-triangle text-yellow-500 mt-0.5\"></i>\r\n            </div>\r\n            <div class=\"ml-3\">\r\n              <h3 class=\"text-sm font-medium text-yellow-800\">학교 이메일 인증이 필요합니다</h3>\r\n              <div class=\"mt-2 text-sm text-yellow-700\">\r\n                <p>상품을 등록하려면 학교 이메일 인증이 필요합니다. 아래 버튼을 클릭하여 이메일 인증을 진행해주세요.</p>\r\n                <div class=\"mt-3\">\r\n                  <router-link \r\n                    to=\"/email-verification\" \r\n                    class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm leading-5 font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-500 focus:outline-none focus:border-yellow-700 focus:shadow-outline-yellow active:bg-yellow-700 transition ease-in-out duration-150\"\r\n                  >\r\n                    이메일 인증하기\r\n                  </router-link>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <form v-if=\"!emailVerificationError\" @submit.prevent=\"submitProduct\" class=\"bg-white rounded-lg shadow-sm p-6\">\r\n          <!-- 상품명 -->\r\n          <div class=\"mb-6\">\r\n            <label for=\"name\" class=\"block text-sm font-medium text-gray-700 mb-1\">상품명</label>\r\n            <input \r\n              id=\"name\"\r\n              v-model=\"product.name\"\r\n              type=\"text\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-md\"\r\n              placeholder=\"상품명을 입력하세요\"\r\n              required\r\n            />\r\n          </div>\r\n          \r\n          <!-- 가격 -->\r\n          <div class=\"mb-6\">\r\n            <label for=\"price\" class=\"block text-sm font-medium text-gray-700 mb-1\">가격</label>\r\n            <div class=\"relative\">\r\n              <input \r\n                id=\"price\"\r\n                v-model=\"product.price\"\r\n                type=\"number\"\r\n                class=\"w-full p-2 border border-gray-300 rounded-md\"\r\n                placeholder=\"가격을 입력하세요\"\r\n                min=\"100\"\r\n                required\r\n              />\r\n              <span class=\"absolute right-3 top-2 text-gray-500\">원</span>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 재고 수량 -->\r\n          <div class=\"mb-6\">\r\n            <label for=\"stock\" class=\"block text-sm font-medium text-gray-700 mb-1\">재고 수량</label>\r\n            <input \r\n              id=\"stock\"\r\n              v-model=\"product.stock\"\r\n              type=\"number\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-md\"\r\n              placeholder=\"수량을 입력하세요\"\r\n              min=\"1\"\r\n              required\r\n            />\r\n          </div>\r\n          \r\n          <!-- 카테고리 -->\r\n          <div class=\"mb-6\">\r\n            <label for=\"category\" class=\"block text-sm font-medium text-gray-700 mb-1\">카테고리</label>\r\n            <select \r\n              id=\"category\"\r\n              v-model=\"product.category\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-md\"\r\n              required\r\n            >\r\n              <option value=\"\" disabled>카테고리 선택</option>\r\n              <option v-for=\"category in categories\" :key=\"category.id\" :value=\"category.id\">\r\n                {{ category.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          \r\n          <!-- 상품 설명 -->\r\n          <div class=\"mb-6\">\r\n            <label for=\"description\" class=\"block text-sm font-medium text-gray-700 mb-1\">상품 설명</label>\r\n            <textarea \r\n              id=\"description\"\r\n              v-model=\"product.description\"\r\n              rows=\"5\"\r\n              class=\"w-full p-2 border border-gray-300 rounded-md\"\r\n              placeholder=\"상품 설명을 입력하세요\"\r\n            ></textarea>\r\n          </div>\r\n          \r\n          <!-- 이미지 업로드 -->\r\n          <div class=\"mb-6\">\r\n            <label class=\"block text-sm font-medium text-gray-700 mb-1\">상품 이미지</label>\r\n            <div class=\"border-2 border-dashed border-gray-300 rounded-md p-4 text-center\">\r\n              <input \r\n                type=\"file\"\r\n                @change=\"handleImageUpload\"\r\n                multiple\r\n                accept=\"image/*\"\r\n                class=\"hidden\"\r\n                ref=\"fileInput\"\r\n              />\r\n              <div v-if=\"previewImages.length === 0\">\r\n                <i class=\"fas fa-cloud-upload-alt text-4xl text-gray-400 mb-2\"></i>\r\n                <p class=\"text-gray-500\">이미지 파일을 드래그하거나 클릭하여 업로드하세요</p>\r\n                <p class=\"text-xs text-gray-400 mt-1\">최대 5개까지 가능 (JPG, PNG)</p>\r\n                <button \r\n                  type=\"button\"\r\n                  @click=\"$refs.fileInput.click()\"\r\n                  class=\"mt-4 px-4 py-2 bg-gray-200 text-gray-800 rounded-md hover:bg-gray-300\"\r\n                >\r\n                  파일 선택\r\n                </button>\r\n              </div>\r\n              \r\n              <div v-else class=\"grid grid-cols-2 sm:grid-cols-3 gap-4\">\r\n                <div \r\n                  v-for=\"(image, index) in previewImages\" \r\n                  :key=\"index\"\r\n                  class=\"relative\"\r\n                >\r\n                  <img :src=\"image.preview\" class=\"w-full h-32 object-cover rounded-md\" />\r\n                  <button \r\n                    type=\"button\"\r\n                    @click=\"removeImage(index)\"\r\n                    class=\"absolute top-1 right-1 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center\"\r\n                  >\r\n                    <i class=\"fas fa-times text-xs\"></i>\r\n                  </button>\r\n                </div>\r\n                <div \r\n                  v-if=\"previewImages.length < 5\"\r\n                  @click=\"$refs.fileInput.click()\"\r\n                  class=\"border-2 border-dashed border-gray-300 rounded-md flex flex-col items-center justify-center h-32 cursor-pointer hover:bg-gray-50\"\r\n                >\r\n                  <i class=\"fas fa-plus text-gray-400\"></i>\r\n                  <span class=\"text-sm text-gray-500 mt-1\">추가</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <div class=\"flex justify-end space-x-3\">\r\n            <router-link \r\n              to=\"/products\" \r\n              class=\"px-4 py-2 border border-gray-300 rounded-md hover:bg-gray-50\"\r\n            >\r\n              취소\r\n            </router-link>\r\n            <button \r\n              type=\"submit\"\r\n              class=\"px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700\"\r\n              :disabled=\"loading\"\r\n            >\r\n              <span v-if=\"loading\">등록 중...</span>\r\n              <span v-else>상품 등록</span>\r\n            </button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </main>\r\n    \r\n    <AppFooter />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AppHeader from '@/components/common/AppHeader.vue'\r\nimport AppFooter from '@/components/common/AppFooter.vue'\r\nimport { mapState, mapActions } from 'vuex'\r\n\r\nexport default {\r\n  name: 'SellProduct',\r\n  \r\n  components: {\r\n    AppHeader,\r\n    AppFooter\r\n  },\r\n  \r\n  data() {\r\n    return {\r\n      product: {\r\n        name: '',\r\n        price: '',\r\n        stock: 1,\r\n        category: '',\r\n        description: ''\r\n      },\r\n      previewImages: [],\r\n      emailVerificationError: false,\r\n      categories: [\r\n        { id: 'BOOKS', name: '교재/서적' },\r\n        { id: 'ELECTRONICS', name: '전자기기' },\r\n        { id: 'FASHION', name: '의류/패션' },\r\n        { id: 'BEAUTY', name: '화장품/미용' },\r\n        { id: 'SPORTS', name: '스포츠/레저' },\r\n        { id: 'HOUSEHOLD', name: '생활용품' },\r\n        { id: 'HOBBY', name: '취미/게임' },\r\n        { id: 'OTHERS', name: '기타' },\r\n      ]\r\n    }\r\n  },\r\n  \r\n  computed: {\r\n    ...mapState('products', ['loading']),\r\n    ...mapState('auth', ['isAuthenticated', 'user'])\r\n  },\r\n  \r\n  created() {\r\n    if (!this.isAuthenticated) {\r\n      this.$router.push({ name: 'Login', query: { redirect: this.$route.fullPath } })\r\n      return;\r\n    }\r\n    \r\n    // 이메일 인증 완료 여부 확인\r\n    if (this.$route.query.emailVerified === 'true') {\r\n      this.emailVerificationError = false;\r\n    } \r\n    // 이미 이메일 인증 오류가 있으면 표시\r\n    else if (this.$route.query.emailError === 'true') {\r\n      this.emailVerificationError = true;\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    ...mapActions('products', ['createProduct']),\r\n    \r\n    handleImageUpload(event) {\r\n      const files = event.target.files\r\n      \r\n      if (files.length === 0) return\r\n      \r\n      // 최대 5개까지만 업로드 가능\r\n      const remainingSlots = 5 - this.previewImages.length\r\n      const selectedFiles = Array.from(files).slice(0, remainingSlots)\r\n      \r\n      selectedFiles.forEach(file => {\r\n        // 파일 유효성 검사 (이미지 파일만)\r\n        if (!file.type.startsWith('image/')) {\r\n          alert('이미지 파일만 업로드 가능합니다.')\r\n          return\r\n        }\r\n        \r\n        // 미리보기 생성\r\n        const reader = new FileReader()\r\n        reader.onload = e => {\r\n          this.previewImages.push({\r\n            file,\r\n            preview: e.target.result\r\n          })\r\n        }\r\n        reader.readAsDataURL(file)\r\n      })\r\n      \r\n      // 파일 입력 초기화\r\n      event.target.value = null\r\n    },\r\n    \r\n    removeImage(index) {\r\n      this.previewImages.splice(index, 1)\r\n    },\r\n    \r\n    async submitProduct() {\r\n      try {\r\n        // FormData 객체 생성\r\n        const productData = {\r\n          name: this.product.name,\r\n          price: Number(this.product.price),\r\n          stock: Number(this.product.stock),\r\n          category: this.product.category,\r\n          status: 'ACTIVE',\r\n          description: this.product.description,\r\n          sellerName: this.user?.name || this.user?.username || ''\r\n        }\r\n        \r\n        // 이미지 파일 추출\r\n        const images = this.previewImages.map(item => item.file)\r\n        \r\n        const response = await this.createProduct({ productData, images })\r\n        \r\n        // 성공 시 상품 상세 페이지로 이동\r\n        this.$router.push({ name: 'ProductDetail', params: { id: response.product.id } })\r\n      } catch (error) {\r\n        console.error('상품 등록 오류:', error)\r\n        \r\n        // 학교 이메일 인증 오류인 경우\r\n        if (error.message && error.message.includes('학교 이메일 인증이 필요합니다')) {\r\n          this.emailVerificationError = true\r\n        } else {\r\n          alert('상품 등록 중 오류가 발생했습니다. 다시 시도해주세요.')\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AAqLA,OAAOA,SAAQ,MAAO,mCAAkC;AACxD,OAAOC,SAAQ,MAAO,mCAAkC;AACxD,SAASC,QAAQ,EAAEC,UAAS,QAAS,MAAK;AAE1C,eAAe;EACbC,IAAI,EAAE,aAAa;EAEnBC,UAAU,EAAE;IACVL,SAAS;IACTC;EACF,CAAC;EAEDK,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE;QACPH,IAAI,EAAE,EAAE;QACRI,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,CAAC;QACRC,QAAQ,EAAE,EAAE;QACZC,WAAW,EAAE;MACf,CAAC;MACDC,aAAa,EAAE,EAAE;MACjBC,sBAAsB,EAAE,KAAK;MAC7BC,UAAU,EAAE,CACV;QAAEC,EAAE,EAAE,OAAO;QAAEX,IAAI,EAAE;MAAQ,CAAC,EAC9B;QAAEW,EAAE,EAAE,aAAa;QAAEX,IAAI,EAAE;MAAO,CAAC,EACnC;QAAEW,EAAE,EAAE,SAAS;QAAEX,IAAI,EAAE;MAAQ,CAAC,EAChC;QAAEW,EAAE,EAAE,QAAQ;QAAEX,IAAI,EAAE;MAAS,CAAC,EAChC;QAAEW,EAAE,EAAE,QAAQ;QAAEX,IAAI,EAAE;MAAS,CAAC,EAChC;QAAEW,EAAE,EAAE,WAAW;QAAEX,IAAI,EAAE;MAAO,CAAC,EACjC;QAAEW,EAAE,EAAE,OAAO;QAAEX,IAAI,EAAE;MAAQ,CAAC,EAC9B;QAAEW,EAAE,EAAE,QAAQ;QAAEX,IAAI,EAAE;MAAK,CAAC;IAEhC;EACF,CAAC;EAEDY,QAAQ,EAAE;IACR,GAAGd,QAAQ,CAAC,UAAU,EAAE,CAAC,SAAS,CAAC,CAAC;IACpC,GAAGA,QAAQ,CAAC,MAAM,EAAE,CAAC,iBAAiB,EAAE,MAAM,CAAC;EACjD,CAAC;EAEDe,OAAOA,CAAA,EAAG;IACR,IAAI,CAAC,IAAI,CAACC,eAAe,EAAE;MACzB,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC;QAAEhB,IAAI,EAAE,OAAO;QAAEiB,KAAK,EAAE;UAAEC,QAAQ,EAAE,IAAI,CAACC,MAAM,CAACC;QAAS;MAAE,CAAC;MAC9E;IACF;;IAEA;IACA,IAAI,IAAI,CAACD,MAAM,CAACF,KAAK,CAACI,aAAY,KAAM,MAAM,EAAE;MAC9C,IAAI,CAACZ,sBAAqB,GAAI,KAAK;IACrC;IACA;IAAA,KACK,IAAI,IAAI,CAACU,MAAM,CAACF,KAAK,CAACK,UAAS,KAAM,MAAM,EAAE;MAChD,IAAI,CAACb,sBAAqB,GAAI,IAAI;IACpC;EACF,CAAC;EAEDc,OAAO,EAAE;IACP,GAAGxB,UAAU,CAAC,UAAU,EAAE,CAAC,eAAe,CAAC,CAAC;IAE5CyB,iBAAiBA,CAACC,KAAK,EAAE;MACvB,MAAMC,KAAI,GAAID,KAAK,CAACE,MAAM,CAACD,KAAI;MAE/B,IAAIA,KAAK,CAACE,MAAK,KAAM,CAAC,EAAE;;MAExB;MACA,MAAMC,cAAa,GAAI,IAAI,IAAI,CAACrB,aAAa,CAACoB,MAAK;MACnD,MAAME,aAAY,GAAIC,KAAK,CAACC,IAAI,CAACN,KAAK,CAAC,CAACO,KAAK,CAAC,CAAC,EAAEJ,cAAc;MAE/DC,aAAa,CAACI,OAAO,CAACC,IAAG,IAAK;QAC5B;QACA,IAAI,CAACA,IAAI,CAACC,IAAI,CAACC,UAAU,CAAC,QAAQ,CAAC,EAAE;UACnCC,KAAK,CAAC,oBAAoB;UAC1B;QACF;;QAEA;QACA,MAAMC,MAAK,GAAI,IAAIC,UAAU,