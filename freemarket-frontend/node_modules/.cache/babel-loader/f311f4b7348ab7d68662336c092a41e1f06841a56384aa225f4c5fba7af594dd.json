{"ast":null,"code":"import AppHeader from '@/components/common/AppHeader.vue';\nimport AppFooter from '@/components/common/AppFooter.vue';\nimport Banner from '@/components/home/Banner.vue';\nimport Categories from '@/components/home/Categories.vue';\nimport ProductList from '@/components/home/ProductList.vue';\nimport { mapState, mapActions } from 'vuex';\nexport default {\n  name: 'HomePage',\n  components: {\n    AppHeader,\n    AppFooter,\n    Banner,\n    Categories,\n    ProductList\n  },\n  data() {\n    return {\n      newProducts: [],\n      popularProducts: [],\n      loading: true\n    };\n  },\n  computed: {\n    ...mapState('auth', ['isAuthenticated', 'isInitialized', 'token', 'user'])\n  },\n  async created() {\n    console.log('Home.vue created - 인증 상태:', this.isAuthenticated);\n    console.log('Home.vue created - 초기화 상태:', this.isInitialized);\n    console.log('Home.vue created - 토큰:', this.token ? '있음' : '없음');\n    console.log('Home.vue created - 사용자:', this.user);\n    try {\n      await this.fetchHomePageProducts();\n    } catch (error) {\n      console.error('홈페이지 상품 로딩 오류:', error);\n    }\n  },\n  methods: {\n    ...mapActions('products', ['fetchProducts']),\n    async fetchHomePageProducts() {\n      this.loading = true;\n      try {\n        // 신규 상품 (최신순, 판매중인 상품만)\n        try {\n          const newProductsResponse = await this.fetchProducts({\n            page: 0,\n            size: 4,\n            status: 'ACTIVE',\n            sort: 'LATEST' // 최신순 정렬 (백엔드 ENUM 값에 맞게 수정)\n          });\n          this.newProducts = newProductsResponse.content || [];\n        } catch (error) {\n          console.error('신규 상품 로딩 오류:', error);\n          this.newProducts = this.getMockProducts(4);\n        }\n\n        // 인기 상품 (조회수 높은 순, 판매중인 상품만)  \n        try {\n          const popularProductsResponse = await this.fetchProducts({\n            page: 0,\n            size: 4,\n            status: 'ACTIVE',\n            sort: 'LATEST' // 최신순 정렬 (백엔드 ENUM 값에 맞게 수정)\n          });\n          this.popularProducts = popularProductsResponse.content || [];\n        } catch (error) {\n          console.error('인기 상품 로딩 오류:', error);\n          this.popularProducts = this.getMockProducts(4);\n        }\n      } catch (error) {\n        console.error('상품 로딩 오류:', error);\n        // API 호출 실패 시 임시 데이터로 대체\n        this.newProducts = this.getMockProducts(4);\n        this.popularProducts = this.getMockProducts(4);\n      } finally {\n        this.loading = false;\n      }\n    },\n    // 모의 데이터 생성 (임시용)\n    getMockProducts(count) {\n      const categories = ['BOOKS', 'ELECTRONICS', 'FASHION', 'HOBBY', 'HOUSEHOLD'];\n      const mockProducts = [];\n      for (let i = 0; i < count; i++) {\n        mockProducts.push({\n          product: {\n            id: i + 1,\n            name: `샘플 상품 ${i + 1}`,\n            price: 10000 * (i + 1),\n            category: categories[i % categories.length],\n            createdAt: new Date().toISOString(),\n            status: 'ACTIVE',\n            thumbnailUrl: null\n          },\n          stats: {\n            viewCount: Math.floor(Math.random() * 100),\n            wishlistCount: Math.floor(Math.random() * 50),\n            isWishlisted: false\n          }\n        });\n      }\n      return mockProducts;\n    }\n  }\n};","map":{"version":3,"names":["AppHeader","AppFooter","Banner","Categories","ProductList","mapState","mapActions","name","components","data","newProducts","popularProducts","loading","computed","created","console","log","isAuthenticated","isInitialized","token","user","fetchHomePageProducts","error","methods","newProductsResponse","fetchProducts","page","size","status","sort","content","getMockProducts","popularProductsResponse","count","categories","mockProducts","i","push","product","id","price","category","length","createdAt","Date","toISOString","thumbnailUrl","stats","viewCount","Math","floor","random","wishlistCount","isWishlisted"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\views\\Home.vue"],"sourcesContent":["<template>\r\n  <div class=\"flex flex-col min-h-screen\">\r\n    <AppHeader />\r\n    <main class=\"flex-1\">\r\n      <Banner />\r\n      <Categories />\r\n      \r\n      <!-- 앱 설명 섹션 -->\r\n      <section class=\"py-16 bg-white\">\r\n        <div class=\"container mx-auto px-4\">\r\n          <div class=\"text-center mb-12\">\r\n            <h2 class=\"text-3xl font-bold mb-4\">FreeMarket과 함께하는 <span class=\"text-blue-600\">안전한 거래</span></h2>\r\n            <p class=\"text-gray-600 max-w-2xl mx-auto\">대학생들을 위한 중고 거래 플랫폼 FreeMarket은 캠퍼스 내 안전하고 편리한 거래를 지원합니다.</p>\r\n          </div>\r\n          \r\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\r\n            <div class=\"bg-gray-50 p-6 rounded-lg text-center hover:shadow-md transition-shadow\">\r\n              <div class=\"w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                <i class=\"fas fa-shield-alt text-2xl\"></i>\r\n              </div>\r\n              <h3 class=\"text-xl font-bold mb-2\">안전한 거래</h3>\r\n              <p class=\"text-gray-600\">신뢰할 수 있는 교내 거래 시스템으로 안전하게 거래하세요.</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gray-50 p-6 rounded-lg text-center hover:shadow-md transition-shadow\">\r\n              <div class=\"w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                <i class=\"fas fa-tags text-2xl\"></i>\r\n              </div>\r\n              <h3 class=\"text-xl font-bold mb-2\">합리적인 가격</h3>\r\n              <p class=\"text-gray-600\">중개 수수료 없이 합리적인 가격으로 물건을 사고 팔 수 있어요.</p>\r\n            </div>\r\n            \r\n            <div class=\"bg-gray-50 p-6 rounded-lg text-center hover:shadow-md transition-shadow\">\r\n              <div class=\"w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                <i class=\"fas fa-graduation-cap text-2xl\"></i>\r\n              </div>\r\n              <h3 class=\"text-xl font-bold mb-2\">학업 맞춤 제품</h3>\r\n              <p class=\"text-gray-600\">교재, 전공 서적 등 학업에 필요한 다양한 상품을 만나보세요.</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n      \r\n      <ProductList title=\"신규 상품\" :products=\"newProducts\" :loading=\"loading\" />\r\n      <ProductList title=\"인기 상품\" :products=\"popularProducts\" :loading=\"loading\" />\r\n      \r\n      <!-- 초기화 중일 때는 CTA 섹션 숨김 -->\r\n      <template v-if=\"isInitialized\">\r\n        <!-- 가입 유도 섹션 (비로그인 사용자) -->\r\n        <section v-if=\"!isAuthenticated\" class=\"py-16 bg-gradient-to-r from-blue-600 to-indigo-600 text-white\">\r\n          <div class=\"container mx-auto px-4 text-center\">\r\n            <h2 class=\"text-3xl font-bold mb-4\">지금 바로 시작하세요!</h2>\r\n            <p class=\"text-xl mb-8\">FreeMarket에서 필요한 물건을 쉽고 안전하게 거래하세요.</p>\r\n            <!-- 디버그 정보 (개발용) -->\r\n            <div v-if=\"$route.query.debug\" class=\"mb-4 text-sm opacity-70\">\r\n              인증상태: {{ isAuthenticated }}, 토큰: {{ token ? '있음' : '없음' }}, 초기화: {{ isInitialized }}\r\n            </div>\r\n            <div class=\"flex justify-center space-x-4\">\r\n              <router-link \r\n                to=\"/register\" \r\n                class=\"px-6 py-3 bg-white text-blue-600 font-bold rounded-lg hover:bg-gray-100 transition-colors\"\r\n              >\r\n                회원가입\r\n              </router-link>\r\n              <router-link \r\n                to=\"/products\" \r\n                class=\"px-6 py-3 bg-transparent border-2 border-white text-white font-bold rounded-lg hover:bg-white hover:bg-opacity-10 transition-colors\"\r\n              >\r\n                상품 둘러보기\r\n              </router-link>\r\n            </div>\r\n          </div>\r\n        </section>\r\n        \r\n        <!-- 로그인한 사용자 전용 섹션 -->\r\n        <section v-else class=\"py-16 bg-gradient-to-r from-blue-600 to-indigo-600 text-white\">\r\n          <div class=\"container mx-auto px-4 text-center\">\r\n            <h2 class=\"text-3xl font-bold mb-4\">환영합니다! 🎉</h2>\r\n            <p class=\"text-xl mb-8\">\r\n              <span v-if=\"user && user.name\">{{ user.name }}님, </span>\r\n              지금 바로 상품을 등록하거나 원하는 상품을 찾아보세요.\r\n            </p>\r\n            <!-- 디버그 정보 (개발용) -->\r\n            <div v-if=\"$route.query.debug\" class=\"mb-4 text-sm opacity-70\">\r\n              인증상태: {{ isAuthenticated }}, 사용자: {{ user ? user.name : '정보없음' }}, 초기화: {{ isInitialized }}\r\n            </div>\r\n            <div class=\"flex justify-center space-x-4\">\r\n              <router-link \r\n                to=\"/products/create\" \r\n                class=\"px-6 py-3 bg-white text-blue-600 font-bold rounded-lg hover:bg-gray-100 transition-colors\"\r\n              >\r\n                상품 등록하기\r\n              </router-link>\r\n              <router-link \r\n                to=\"/products\" \r\n                class=\"px-6 py-3 bg-transparent border-2 border-white text-white font-bold rounded-lg hover:bg-white hover:bg-opacity-10 transition-colors\"\r\n              >\r\n                상품 둘러보기\r\n              </router-link>\r\n            </div>\r\n          </div>\r\n        </section>\r\n      </template>\r\n    </main>\r\n    <AppFooter />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AppHeader from '@/components/common/AppHeader.vue'\r\nimport AppFooter from '@/components/common/AppFooter.vue'\r\nimport Banner from '@/components/home/Banner.vue'\r\nimport Categories from '@/components/home/Categories.vue'\r\nimport ProductList from '@/components/home/ProductList.vue'\r\nimport { mapState, mapActions } from 'vuex'\r\n\r\nexport default {\r\n  name: 'HomePage',\r\n  \r\n  components: {\r\n    AppHeader,\r\n    AppFooter,\r\n    Banner,\r\n    Categories,\r\n    ProductList\r\n  },\r\n  \r\n  data() {\r\n    return {\r\n      newProducts: [],\r\n      popularProducts: [],\r\n      loading: true\r\n    }\r\n  },\r\n  \r\n  computed: {\r\n    ...mapState('auth', ['isAuthenticated', 'isInitialized', 'token', 'user'])\r\n  },\r\n  \r\n  async created() {\r\n    console.log('Home.vue created - 인증 상태:', this.isAuthenticated);\r\n    console.log('Home.vue created - 초기화 상태:', this.isInitialized);\r\n    console.log('Home.vue created - 토큰:', this.token ? '있음' : '없음');\r\n    console.log('Home.vue created - 사용자:', this.user);\r\n    \r\n    try {\r\n      await this.fetchHomePageProducts()\r\n    } catch (error) {\r\n      console.error('홈페이지 상품 로딩 오류:', error)\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    ...mapActions('products', ['fetchProducts']),\r\n    \r\n    async fetchHomePageProducts() {\r\n      this.loading = true;\r\n      \r\n      try {\r\n        // 신규 상품 (최신순, 판매중인 상품만)\r\n        try {\r\n          const newProductsResponse = await this.fetchProducts({\r\n            page: 0,\r\n            size: 4,\r\n            status: 'ACTIVE',\r\n            sort: 'LATEST'  // 최신순 정렬 (백엔드 ENUM 값에 맞게 수정)\r\n          });\r\n          this.newProducts = newProductsResponse.content || [];\r\n        } catch (error) {\r\n          console.error('신규 상품 로딩 오류:', error);\r\n          this.newProducts = this.getMockProducts(4);\r\n        }\r\n        \r\n        // 인기 상품 (조회수 높은 순, 판매중인 상품만)  \r\n        try {\r\n          const popularProductsResponse = await this.fetchProducts({\r\n            page: 0,\r\n            size: 4,\r\n            status: 'ACTIVE',\r\n            sort: 'LATEST'  // 최신순 정렬 (백엔드 ENUM 값에 맞게 수정)\r\n          });\r\n          this.popularProducts = popularProductsResponse.content || [];\r\n        } catch (error) {\r\n          console.error('인기 상품 로딩 오류:', error);\r\n          this.popularProducts = this.getMockProducts(4);\r\n        }\r\n      } catch (error) {\r\n        console.error('상품 로딩 오류:', error);\r\n        // API 호출 실패 시 임시 데이터로 대체\r\n        this.newProducts = this.getMockProducts(4);\r\n        this.popularProducts = this.getMockProducts(4);\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    \r\n    // 모의 데이터 생성 (임시용)\r\n    getMockProducts(count) {\r\n      const categories = ['BOOKS', 'ELECTRONICS', 'FASHION', 'HOBBY', 'HOUSEHOLD'];\r\n      const mockProducts = [];\r\n      \r\n      for (let i = 0; i < count; i++) {\r\n        mockProducts.push({\r\n          product: {\r\n            id: i + 1,\r\n            name: `샘플 상품 ${i + 1}`,\r\n            price: 10000 * (i + 1),\r\n            category: categories[i % categories.length],\r\n            createdAt: new Date().toISOString(),\r\n            status: 'ACTIVE',\r\n            thumbnailUrl: null\r\n          },\r\n          stats: {\r\n            viewCount: Math.floor(Math.random() * 100),\r\n            wishlistCount: Math.floor(Math.random() * 50),\r\n            isWishlisted: false\r\n          }\r\n        });\r\n      }\r\n      \r\n      return mockProducts;\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@media (max-width: 768px) {\r\n  .md\\:grid-cols-3 {\r\n    grid-template-columns: repeat(1, minmax(0, 1fr));\r\n  }\r\n  \r\n  .py-16 {\r\n    padding-top: 2rem;\r\n    padding-bottom: 2rem;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA6GA,OAAOA,SAAQ,MAAO,mCAAkC;AACxD,OAAOC,SAAQ,MAAO,mCAAkC;AACxD,OAAOC,MAAK,MAAO,8BAA6B;AAChD,OAAOC,UAAS,MAAO,kCAAiC;AACxD,OAAOC,WAAU,MAAO,mCAAkC;AAC1D,SAASC,QAAQ,EAAEC,UAAS,QAAS,MAAK;AAE1C,eAAe;EACbC,IAAI,EAAE,UAAU;EAEhBC,UAAU,EAAE;IACVR,SAAS;IACTC,SAAS;IACTC,MAAM;IACNC,UAAU;IACVC;EACF,CAAC;EAEDK,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,EAAE;MACfC,eAAe,EAAE,EAAE;MACnBC,OAAO,EAAE;IACX;EACF,CAAC;EAEDC,QAAQ,EAAE;IACR,GAAGR,QAAQ,CAAC,MAAM,EAAE,CAAC,iBAAiB,EAAE,eAAe,EAAE,OAAO,EAAE,MAAM,CAAC;EAC3E,CAAC;EAED,MAAMS,OAAOA,CAAA,EAAG;IACdC,OAAO,CAACC,GAAG,CAAC,2BAA2B,EAAE,IAAI,CAACC,eAAe,CAAC;IAC9DF,OAAO,CAACC,GAAG,CAAC,4BAA4B,EAAE,IAAI,CAACE,aAAa,CAAC;IAC7DH,OAAO,CAACC,GAAG,CAAC,wBAAwB,EAAE,IAAI,CAACG,KAAI,GAAI