{"ast":null,"code":"import ProductCard from '@/components/products/ProductCard.vue';\nexport default {\n  name: 'HomeProductList',\n  components: {\n    ProductCard\n  },\n  props: {\n    title: {\n      type: String,\n      required: true\n    },\n    products: {\n      type: Array,\n      default: () => []\n    },\n    loading: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    goToProduct(id) {\n      this.$router.push({\n        name: 'ProductDetail',\n        params: {\n          id\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["ProductCard","name","components","props","title","type","String","required","products","Array","default","loading","Boolean","methods","goToProduct","id","$router","push","params"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\components\\home\\ProductList.vue"],"sourcesContent":["<template>\r\n  <div class=\"py-10 bg-gray-50\">\r\n    <div class=\"container mx-auto px-4\">\r\n      <div class=\"flex justify-between items-center mb-6\">\r\n        <h2 class=\"text-2xl font-bold\">{{ title }}</h2>\r\n        <router-link to=\"/products\" class=\"text-blue-600 hover:underline flex items-center\">\r\n          더보기 <i class=\"fas fa-chevron-right ml-1 text-xs\"></i>\r\n        </router-link>\r\n      </div>\r\n      \r\n      <div v-if=\"loading\" class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6\">\r\n        <div v-for=\"i in 4\" :key=\"i\" class=\"bg-white animate-pulse h-72 rounded-lg shadow-sm p-4\">\r\n          <div class=\"bg-gray-200 h-40 rounded mb-4\"></div>\r\n          <div class=\"h-5 bg-gray-200 rounded mb-2\"></div>\r\n          <div class=\"h-4 bg-gray-200 rounded w-1/2\"></div>\r\n        </div>\r\n      </div>\r\n      \r\n      <div v-else-if=\"!products || products.length === 0\" class=\"text-center py-8 text-gray-500 bg-white p-8 rounded-lg shadow-sm\">\r\n        <i class=\"far fa-frown text-4xl mb-4 text-gray-400\"></i>\r\n        <p>상품이 없습니다.</p>\r\n        <router-link \r\n          to=\"/sell\" \r\n          class=\"mt-4 inline-block px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors\"\r\n        >\r\n          상품 등록하기\r\n        </router-link>\r\n      </div>\r\n      \r\n      <div v-else class=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6\">\r\n        <ProductCard \r\n          v-for=\"product in products\" \r\n          :key=\"product.product.id\"\r\n          :product=\"product.product\"\r\n          :stats=\"product.stats\"\r\n          @click=\"goToProduct(product.product.id)\"\r\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport ProductCard from '@/components/products/ProductCard.vue'\r\n\r\nexport default {\r\n  name: 'HomeProductList',\r\n  \r\n  components: {\r\n    ProductCard\r\n  },\r\n  \r\n  props: {\r\n    title: {\r\n      type: String,\r\n      required: true\r\n    },\r\n    products: {\r\n      type: Array,\r\n      default: () => []\r\n    },\r\n    loading: {\r\n      type: Boolean,\r\n      default: false\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    goToProduct(id) {\r\n      this.$router.push({ name: 'ProductDetail', params: { id } })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@media (max-width: 768px) {\r\n  .lg\\:grid-cols-4 {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n  .lg\\:grid-cols-4,\r\n  .md\\:grid-cols-3,\r\n  .sm\\:grid-cols-2 {\r\n    grid-template-columns: repeat(1, minmax(0, 1fr));\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA2CA,OAAOA,WAAU,MAAO,uCAAsC;AAE9D,eAAe;EACbC,IAAI,EAAE,iBAAiB;EAEvBC,UAAU,EAAE;IACVF;EACF,CAAC;EAEDG,KAAK,EAAE;IACLC,KAAK,EAAE;MACLC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,QAAQ,EAAE;MACRH,IAAI,EAAEI,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM;IACjB,CAAC;IACDC,OAAO,EAAE;MACPN,IAAI,EAAEO,OAAO;MACbF,OAAO,EAAE;IACX;EACF,CAAC;EAEDG,OAAO