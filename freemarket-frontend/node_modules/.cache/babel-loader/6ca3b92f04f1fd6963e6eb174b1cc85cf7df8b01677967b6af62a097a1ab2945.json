{"ast":null,"code":"export default {\n  name: 'AppPagination',\n  props: {\n    currentPage: {\n      type: Number,\n      required: true\n    },\n    totalPages: {\n      type: Number,\n      required: true,\n      default: 1\n    },\n    totalItems: {\n      type: Number,\n      default: 0\n    },\n    itemsPerPage: {\n      type: Number,\n      default: 10\n    }\n  },\n  computed: {\n    displayedPageNumbers() {\n      const pageNumbers = [];\n\n      // 최대 5개의 페이지 번호를 표시\n      const calculatedTotalPages = this.totalPages || Math.ceil(this.totalItems / this.itemsPerPage) || 1;\n      let startPage = Math.max(1, this.currentPage - 2);\n      let endPage = Math.min(calculatedTotalPages, startPage + 4);\n      if (endPage - startPage < 4) {\n        startPage = Math.max(1, endPage - 4);\n      }\n      for (let i = startPage; i <= endPage; i++) {\n        pageNumbers.push(i);\n      }\n      return pageNumbers;\n    }\n  },\n  methods: {\n    handlePageChange(page) {\n      // 유효한 페이지 범위 확인\n      if (page < 1 || page > this.totalPages) {\n        console.warn('유효하지 않은 페이지 번호:', page);\n        return;\n      }\n\n      // 현재 페이지와 다를 때만 이벤트 발생\n      if (page !== this.currentPage) {\n        console.log('페이지 변경 이벤트 발생:', page);\n        this.$emit('page-changed', page);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","props","currentPage","type","Number","required","totalPages","default","totalItems","itemsPerPage","computed","displayedPageNumbers","pageNumbers","calculatedTotalPages","Math","ceil","startPage","max","endPage","min","i","push","methods","handlePageChange","page","console","warn","log","$emit"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\components\\common\\AppPagination.vue"],"sourcesContent":["<template>\r\n  <div class=\"flex justify-center mt-8\">\r\n    <nav class=\"flex items-center space-x-1\">\r\n      <button\r\n        @click=\"handlePageChange(currentPage - 1)\"\r\n        :disabled=\"currentPage <= 1\"\r\n        class=\"px-3 py-1 rounded border border-gray-300 disabled:opacity-50\"\r\n      >\r\n        이전\r\n      </button>\r\n      \r\n      <button\r\n        v-for=\"number in displayedPageNumbers\"\r\n        :key=\"number\"\r\n        @click=\"handlePageChange(number)\"\r\n        :class=\"[\r\n          'px-3 py-1 rounded',\r\n          currentPage === number \r\n            ? 'bg-blue-600 text-white' \r\n            : 'border border-gray-300'\r\n        ]\"\r\n      >\r\n        {{ number }}\r\n      </button>\r\n      \r\n      <button\r\n        @click=\"handlePageChange(currentPage + 1)\"\r\n        :disabled=\"currentPage >= totalPages\"\r\n        class=\"px-3 py-1 rounded border border-gray-300 disabled:opacity-50\"\r\n      >\r\n        다음\r\n      </button>\r\n    </nav>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'AppPagination',\r\n  \r\n  props: {\r\n    currentPage: {\r\n      type: Number,\r\n      required: true\r\n    },\r\n    totalPages: {\r\n      type: Number,\r\n      required: true,\r\n      default: 1\r\n    },\r\n    totalItems: {\r\n      type: Number,\r\n      default: 0\r\n    },\r\n    itemsPerPage: {\r\n      type: Number,\r\n      default: 10\r\n    }\r\n  },\r\n  \r\n  computed: {\r\n    displayedPageNumbers() {\r\n      const pageNumbers = []\r\n      \r\n      // 최대 5개의 페이지 번호를 표시\r\n      const calculatedTotalPages = this.totalPages || Math.ceil(this.totalItems / this.itemsPerPage) || 1;\r\n      \r\n      let startPage = Math.max(1, this.currentPage - 2)\r\n      let endPage = Math.min(calculatedTotalPages, startPage + 4)\r\n      \r\n      if (endPage - startPage < 4) {\r\n        startPage = Math.max(1, endPage - 4)\r\n      }\r\n      \r\n      for (let i = startPage; i <= endPage; i++) {\r\n        pageNumbers.push(i)\r\n      }\r\n      \r\n      return pageNumbers\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    handlePageChange(page) {\r\n      // 유효한 페이지 범위 확인\r\n      if (page < 1 || page > this.totalPages) {\r\n        console.warn('유효하지 않은 페이지 번호:', page);\r\n        return;\r\n      }\r\n      \r\n      // 현재 페이지와 다를 때만 이벤트 발생\r\n      if (page !== this.currentPage) {\r\n        console.log('페이지 변경 이벤트 발생:', page);\r\n        this.$emit('page-changed', page);\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AAqCA,eAAe;EACbA,IAAI,EAAE,eAAe;EAErBC,KAAK,EAAE;IACLC,WAAW,EAAE;MACXC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,UAAU,EAAE;MACVH,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE,IAAI;MACdE,OAAO,EAAE;IACX,CAAC;IACDC,UAAU,EAAE;MACVL,IAAI,EAAEC,MAAM;MACZG,OAAO,EAAE;IACX,CAAC;IACDE,YAAY,EAAE;MACZN,IAAI,EAAEC,MAAM;MACZG,OAAO,EAAE;IACX;EACF,CAAC;EAEDG,QAAQ,EAAE;IACRC,oBAAoBA,CAAA,EAAG;MACrB,MAAMC,WAAU,GAAI,EAAC;;MAErB;MACA,MAAMC,oBAAmB,GAAI,IAAI,CAACP,UAAS,IAAKQ,IAAI,CAACC,IAAI,CAAC,IAAI,CAACP,UAAS,GAAI,IAAI,CAACC,YAAY,KAAK,CAAC;MAEnG,IAAIO,SAAQ,GAAIF,IAAI,CAACG,GAAG,CAAC,CAAC,EAAE,IAAI,CAACf,WAAU,GAAI,CAAC;MAChD,IAAIgB,OAAM,GAAIJ,IAAI,CAACK,GAAG,CAACN,oBAAoB,EAAEG,SAAQ,GAAI,CAAC;MAE1D,IAAIE,OAAM,GAAIF,SAAQ,GAAI,CAAC,EAAE;QAC3BA,SAAQ,GAAIF,IAAI,CAACG,GAAG,CAAC,CAAC,EAAEC,OAAM,GAAI,CAAC;MACrC;MAEA,KAAK,IAAIE,CAAA,GAAIJ,SAAS,EAAEI,CAAA,IAAKF,OAAO,EAAEE,CAAC,EAAE,EAAE;QACzCR,WAAW,CAACS,IAAI,CAACD,CAAC;MACpB;MAEA,OAAOR,WAAU;IACnB;EACF,CAAC;EAEDU,OAAO,EAAE;IACPC,gBAAgBA,CAACC,IAAI,EAAE;MACrB;MACA,IAAIA,IAAG,GAAI,KAAKA,IAAG,GAAI,IAAI,CAAClB,UAAU,EAAE;QACtCmB,OAAO,CAACC,IAAI,CAAC,iBAAiB,EAAEF,IAAI,CAAC;QACrC;MACF;;MAEA;MACA,IAAIA,IAAG,KAAM,IAAI,CAACtB,WAAW,EAAE;QAC7BuB,OAAO,CAACE,GAAG,CAAC,gBAAgB,EAAEH,IAAI,CAAC;QACnC,IAAI,CAACI,KAAK,CAAC,cAAc,EAAEJ,IAAI,CAAC;MAClC;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}