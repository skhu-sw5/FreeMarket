{"ast":null,"code":"export default {\n  name: 'ProductGallery',\n  props: {\n    images: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      selectedIndex: 0,\n      baseUrl: 'https://freemarket.duckdns.org' // API 서버 기본 URL\n    };\n  },\n  methods: {\n    getImageUrl(url) {\n      if (!url) return 'https://via.placeholder.com/600x400';\n\n      // 이미 전체 URL인 경우 그대로 반환\n      if (url.startsWith('http://') || url.startsWith('https://')) {\n        return url;\n      }\n\n      // 상대 경로인 경우 baseUrl 추가\n      return `${this.baseUrl}${url}`;\n    }\n  },\n  watch: {\n    images() {\n      this.selectedIndex = 0;\n    }\n  }\n};","map":{"version":3,"names":["name","props","images","type","Array","default","data","selectedIndex","baseUrl","methods","getImageUrl","url","startsWith","watch"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\components\\products\\ProductGallery.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"mb-4 rounded-lg overflow-hidden bg-gray-100\">\r\n      <img \r\n        :src=\"getImageUrl(images[selectedIndex]?.url)\" \r\n        alt=\"상품 이미지\" \r\n        class=\"w-full h-80 md:h-96 object-contain\"\r\n      />\r\n    </div>\r\n    \r\n    <div v-if=\"images.length > 1\" class=\"grid grid-cols-5 gap-2\">\r\n      <div \r\n        v-for=\"(image, index) in images\" \r\n        :key=\"index\"\r\n        @click=\"selectedIndex = index\"\r\n        :class=\"[\r\n          'cursor-pointer rounded-md overflow-hidden border-2',\r\n          selectedIndex === index ? 'border-blue-500' : 'border-transparent'\r\n        ]\"\r\n      >\r\n        <img :src=\"getImageUrl(image.thumbnail)\" :alt=\"`썸네일 ${index + 1}`\" class=\"w-full h-16 object-cover\" />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'ProductGallery',\r\n  \r\n  props: {\r\n    images: {\r\n      type: Array,\r\n      default: () => []\r\n    }\r\n  },\r\n  \r\n\r\n  data() {\r\n    return {\r\n      selectedIndex: 0,\r\n      baseUrl: 'https://freemarket.duckdns.org' // API 서버 기본 URL\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    getImageUrl(url) {\r\n      if (!url) return 'https://via.placeholder.com/600x400';\r\n      \r\n      // 이미 전체 URL인 경우 그대로 반환\r\n      if (url.startsWith('http://') || url.startsWith('https://')) {\r\n        return url;\r\n      }\r\n      \r\n      // 상대 경로인 경우 baseUrl 추가\r\n      return `${this.baseUrl}${url}`;\r\n    }\r\n  },\r\n  \r\n  watch: {\r\n    images() {\r\n      this.selectedIndex = 0\r\n    }\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AA2BA,eAAe;EACbA,IAAI,EAAE,gBAAgB;EAEtBC,KAAK,EAAE;IACLC,MAAM,EAAE;MACNC,IAAI,EAAEC,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM;IACjB;EACF,CAAC;EAGDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE,CAAC;MAChBC,OAAO,EAAE,gCAA+B,CAAE;IAC5C;EACF,CAAC;EAEDC,OAAO,EAAE;IACPC,WAAWA,CAACC,GAAG,EAAE;MACf,IAAI,CAACA,GAAG,EAAE,OAAO,qCAAqC;;MAEtD;MACA,IAAIA,GAAG,CAACC,UAAU,CAAC,SAAS,KAAKD,GAAG,CAACC,UAAU,CAAC,UAAU,CAAC,EAAE;QAC3D,OAAOD,GAAG;MACZ;;MAEA;MACA,OAAO,GAAG,IAAI,CAACH,OAAO,GAAGG,GAAG,EAAE;IAChC;EACF,CAAC;EAEDE,KAAK,EAAE;IACLX,MAAMA,CAAA,EAAG;MACP,IAAI,CAACK,aAAY,GAAI;IACvB;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}