{"ast":null,"code":"import AppHeader from '@/components/common/AppHeader.vue';\nimport AppFooter from '@/components/common/AppFooter.vue';\nimport EmailVerification from '@/components/user/EmailVerification.vue';\nexport default {\n  name: 'EmailVerificationPage',\n  components: {\n    AppHeader,\n    AppFooter,\n    EmailVerification\n  },\n  // 이메일 인증 페이지에서 나갈 때 사용자 정보 강제 갱신\n  beforeRouteLeave(to, from, next) {\n    // 프로필 페이지로 이동하는 경우에만 처리\n    if (to.path === '/profile') {\n      console.log('이메일 인증 페이지에서 프로필로 이동합니다. 사용자 정보를 새로고침합니다.');\n      this.$store.dispatch('auth/fetchUser').then(() => {\n        next();\n      }).catch(() => {\n        // 오류가 발생해도 이동은 허용\n        next();\n      });\n    } else {\n      next();\n    }\n  }\n};","map":{"version":3,"names":["AppHeader","AppFooter","EmailVerification","name","components","beforeRouteLeave","to","from","next","path","console","log","$store","dispatch","then","catch"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\views\\user\\EmailVerificationPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"min-h-screen bg-gray-50 flex flex-col\">\r\n    <AppHeader />\r\n    \r\n    <main class=\"py-6 flex-grow\">\r\n      <div class=\"container mx-auto px-4\">\r\n        <!-- 여기서 h1 태그를 제거하여 중복 제목을 제거합니다 -->\r\n        \r\n        <div class=\"max-w-2xl mx-auto\">\r\n          <EmailVerification />\r\n        </div>\r\n      </div>\r\n    </main>\r\n    \r\n    <AppFooter />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AppHeader from '@/components/common/AppHeader.vue';\r\nimport AppFooter from '@/components/common/AppFooter.vue';\r\nimport EmailVerification from '@/components/user/EmailVerification.vue';\r\n\r\nexport default {\r\n  name: 'EmailVerificationPage',\r\n  \r\n  components: {\r\n    AppHeader,\r\n    AppFooter,\r\n    EmailVerification\r\n  },\r\n  \r\n  // 이메일 인증 페이지에서 나갈 때 사용자 정보 강제 갱신\r\n  beforeRouteLeave(to, from, next) {\r\n    // 프로필 페이지로 이동하는 경우에만 처리\r\n    if (to.path === '/profile') {\r\n      console.log('이메일 인증 페이지에서 프로필로 이동합니다. 사용자 정보를 새로고침합니다.');\r\n      this.$store.dispatch('auth/fetchUser')\r\n        .then(() => {\r\n          next();\r\n        })\r\n        .catch(() => {\r\n          // 오류가 발생해도 이동은 허용\r\n          next();\r\n        });\r\n    } else {\r\n      next();\r\n    }\r\n  }\r\n};\r\n</script>\r\n"],"mappings":"AAmBA,OAAOA,SAAQ,MAAO,mCAAmC;AACzD,OAAOC,SAAQ,MAAO,mCAAmC;AACzD,OAAOC,iBAAgB,MAAO,yCAAyC;AAEvE,eAAe;EACbC,IAAI,EAAE,uBAAuB;EAE7BC,UAAU,EAAE;IACVJ,SAAS;IACTC,SAAS;IACTC;EACF,CAAC;EAED;EACAG,gBAAgBA,CAACC,EAAE,EAAEC,IAAI,EAAEC,IAAI,EAAE;IAC/B;IACA,IAAIF,EAAE,CAACG,IAAG,KAAM,UAAU,EAAE;MAC1BC,OAAO,CAACC,GAAG,CAAC,2CAA2C,CAAC;MACxD,IAAI,CAACC,MAAM,CAACC,QAAQ,CAAC,gBAAgB,EAClCC,IAAI,CAAC,MAAM;QACVN,IAAI,CAAC,CAAC;MACR,CAAC,EACAO,KAAK,CAAC,MAAM;QACX;QACAP,IAAI,CAAC,CAAC;MACR,CAAC,CAAC;IACN,OAAO;MACLA,IAAI,CAAC,CAAC;IACR;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}