{"ast":null,"code":"export default {\n  name: 'ProductFilters',\n  props: {\n    filters: {\n      type: Object,\n      required: true\n    },\n    categories: {\n      type: Array,\n      default: () => [{\n        id: 'BOOKS',\n        name: '교재/서적'\n      }, {\n        id: 'ELECTRONICS',\n        name: '전자기기'\n      }, {\n        id: 'FASHION',\n        name: '의류/패션'\n      }, {\n        id: 'BEAUTY',\n        name: '화장품/미용'\n      }, {\n        id: 'SPORTS',\n        name: '스포츠/레저'\n      }, {\n        id: 'HOUSEHOLD',\n        name: '생활용품'\n      }, {\n        id: 'HOBBY',\n        name: '취미/게임'\n      }, {\n        id: 'OTHERS',\n        name: '기타'\n      }]\n    },\n    activeCategory: {\n      type: String,\n      default: null\n    }\n  },\n  data() {\n    return {\n      isFilterOpen: false,\n      priceRange: {\n        min: this.filters.priceRange?.min || '',\n        max: this.filters.priceRange?.max || ''\n      },\n      selectedStatus: this.filters.status || 'ACTIVE',\n      sortOption: 'LATEST' // 기본값 최신순\n    };\n  },\n  methods: {\n    applyFilters() {\n      this.$emit('update:filters', {\n        priceRange: this.priceRange,\n        status: this.selectedStatus\n      });\n      this.isFilterOpen = false;\n    },\n    applySortOption() {\n      this.$emit('sort-change', this.sortOption);\n    },\n    reset() {\n      this.priceRange = {\n        min: '',\n        max: ''\n      };\n      this.selectedStatus = 'ACTIVE';\n      this.sortOption = 'LATEST';\n      this.$emit('reset');\n    }\n  }\n};","map":{"version":3,"names":["name","props","filters","type","Object","required","categories","Array","default","id","activeCategory","String","data","isFilterOpen","priceRange","min","max","selectedStatus","status","sortOption","methods","applyFilters","$emit","applySortOption","reset"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\components\\products\\ProductFilters.vue"],"sourcesContent":["<template>\r\n  <div class=\"bg-white shadow-sm mb-6 rounded-lg\">\r\n    <div class=\"container py-3\">\r\n      <!-- 카테고리 필터 -->\r\n      <div class=\"overflow-x-auto pb-3\">\r\n        <div class=\"flex space-x-2 min-w-max\">\r\n          <button\r\n            @click=\"$emit('category-change', null)\"\r\n            :class=\"[\r\n              'px-3 py-1.5 rounded-lg',\r\n              activeCategory === null \r\n                ? 'bg-blue-600 text-white' \r\n                : 'bg-gray-100 text-gray-800 hover:bg-gray-200'\r\n            ]\"\r\n          >\r\n            전체\r\n          </button>\r\n          <button\r\n            v-for=\"category in categories\"\r\n            :key=\"category.id\"\r\n            @click=\"$emit('category-change', category.id)\"\r\n            :class=\"[\r\n              'px-3 py-1.5 rounded-lg whitespace-nowrap',\r\n              activeCategory === category.id \r\n                ? 'bg-blue-600 text-white' \r\n                : 'bg-gray-100 text-gray-800 hover:bg-gray-200'\r\n            ]\"\r\n          >\r\n            {{ category.name }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- 필터 버튼과 정렬 옵션 -->\r\n      <div class=\"border-t pt-3 flex justify-between items-center\">\r\n        <button \r\n          class=\"px-4 py-2 border border-blue-600 text-blue-600 rounded-lg font-medium hover:bg-blue-50 transition-colors flex items-center space-x-1\"\r\n          @click=\"isFilterOpen = !isFilterOpen\"\r\n        >\r\n          <i class=\"fas fa-sliders-h\"></i>\r\n          <span>필터</span>\r\n        </button>\r\n        \r\n        <div class=\"flex space-x-2\">\r\n          <select v-model=\"sortOption\" @change=\"applySortOption\" class=\"border px-2 py-1 rounded\">\r\n            <option value=\"LATEST\">최신순</option>\r\n            <option value=\"PRICE_ASC\">낮은 가격순</option>\r\n            <option value=\"PRICE_DESC\">높은 가격순</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- 필터 패널 -->\r\n      <div v-if=\"isFilterOpen\" class=\"mt-4 p-4 border rounded-lg\">\r\n        <div class=\"flex justify-between items-center mb-4\">\r\n          <h3 class=\"font-medium\">상세 필터</h3>\r\n          <button @click=\"isFilterOpen = false\">\r\n            <i class=\"fas fa-times text-gray-500\"></i>\r\n          </button>\r\n        </div>\r\n        \r\n        <div class=\"space-y-4\">\r\n          <!-- 가격 범위 -->\r\n          <div>\r\n            <h4 class=\"text-sm font-medium mb-2\">가격 범위</h4>\r\n            <div class=\"flex items-center space-x-2\">\r\n              <input\r\n                v-model=\"priceRange.min\"\r\n                type=\"number\"\r\n                placeholder=\"최소 가격\"\r\n                class=\"border rounded-lg px-3 py-1.5 w-full\"\r\n              />\r\n              <span>-</span>\r\n              <input\r\n                v-model=\"priceRange.max\"\r\n                type=\"number\"\r\n                placeholder=\"최대 가격\"\r\n                class=\"border rounded-lg px-3 py-1.5 w-full\"\r\n              />\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 상품 상태 -->\r\n          <div>\r\n            <h4 class=\"text-sm font-medium mb-2\">상품 상태</h4>\r\n            <div class=\"flex space-x-2\">\r\n              <button\r\n                @click=\"selectedStatus = 'ACTIVE'\"\r\n                :class=\"[\r\n                  'px-3 py-1.5 rounded-lg',\r\n                  selectedStatus === 'ACTIVE' \r\n                    ? 'bg-blue-600 text-white' \r\n                    : 'bg-gray-100 text-gray-800'\r\n                ]\"\r\n              >\r\n                판매중\r\n              </button>\r\n              <button\r\n                @click=\"selectedStatus = 'SOLD_OUT'\"\r\n                :class=\"[\r\n                  'px-3 py-1.5 rounded-lg',\r\n                  selectedStatus === 'SOLD_OUT' \r\n                    ? 'bg-blue-600 text-white' \r\n                    : 'bg-gray-100 text-gray-800'\r\n                ]\"\r\n              >\r\n                품절\r\n              </button>\r\n            </div>\r\n          </div>\r\n          \r\n          <div class=\"pt-2\">\r\n            <button \r\n              @click=\"applyFilters\"\r\n              class=\"w-full px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors\"\r\n            >\r\n              필터 적용\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'ProductFilters',\r\n  \r\n  props: {\r\n    filters: {\r\n      type: Object,\r\n      required: true\r\n    },\r\n    categories: {\r\n      type: Array,\r\n      default: () => [\r\n        { id: 'BOOKS', name: '교재/서적' },\r\n        { id: 'ELECTRONICS', name: '전자기기' },\r\n        { id: 'FASHION', name: '의류/패션' },\r\n        { id: 'BEAUTY', name: '화장품/미용' },\r\n        { id: 'SPORTS', name: '스포츠/레저' },\r\n        { id: 'HOUSEHOLD', name: '생활용품' },\r\n        { id: 'HOBBY', name: '취미/게임' },\r\n        { id: 'OTHERS', name: '기타' }\r\n      ]\r\n    },\r\n    activeCategory: {\r\n      type: String,\r\n      default: null\r\n    }\r\n  },\r\n  \r\n  data() {\r\n    return {\r\n      isFilterOpen: false,\r\n      priceRange: { \r\n        min: this.filters.priceRange?.min || '', \r\n        max: this.filters.priceRange?.max || '' \r\n      },\r\n      selectedStatus: this.filters.status || 'ACTIVE',\r\n      sortOption: 'LATEST' // 기본값 최신순\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    applyFilters() {\r\n      this.$emit('update:filters', {\r\n        priceRange: this.priceRange,\r\n        status: this.selectedStatus\r\n      })\r\n      this.isFilterOpen = false\r\n    },\r\n    \r\n    applySortOption() {\r\n      this.$emit('sort-change', this.sortOption);\r\n    },\r\n    \r\n    reset() {\r\n      this.priceRange = { min: '', max: '' };\r\n      this.selectedStatus = 'ACTIVE';\r\n      this.sortOption = 'LATEST';\r\n      this.$emit('reset');\r\n    }\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AA8HA,eAAe;EACbA,IAAI,EAAE,gBAAgB;EAEtBC,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,UAAU,EAAE;MACVH,IAAI,EAAEI,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM,CACb;QAAEC,EAAE,EAAE,OAAO;QAAET,IAAI,EAAE;MAAQ,CAAC,EAC9B;QAAES,EAAE,EAAE,aAAa;QAAET,IAAI,EAAE;MAAO,CAAC,EACnC;QAAES,EAAE,EAAE,SAAS;QAAET,IAAI,EAAE;MAAQ,CAAC,EAChC;QAAES,EAAE,EAAE,QAAQ;QAAET,IAAI,EAAE;MAAS,CAAC,EAChC;QAAES,EAAE,EAAE,QAAQ;QAAET,IAAI,EAAE;MAAS,CAAC,EAChC;QAAES,EAAE,EAAE,WAAW;QAAET,IAAI,EAAE;MAAO,CAAC,EACjC;QAAES,EAAE,EAAE,OAAO;QAAET,IAAI,EAAE;MAAQ,CAAC,EAC9B;QAAES,EAAE,EAAE,QAAQ;QAAET,IAAI,EAAE;MAAK;IAE/B,CAAC;IACDU,cAAc,EAAE;MACdP,IAAI,EAAEQ,MAAM;MACZH,OAAO,EAAE;IACX;EACF,CAAC;EAEDI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,YAAY,EAAE,KAAK;MACnBC,UAAU,EAAE;QACVC,GAAG,EAAE,IAAI,CAACb,OAAO,CAACY,UAAU,EAAEC,GAAE,IAAK,EAAE;QACvCC,GAAG,EAAE,IAAI,CAACd,OAAO,CAACY,UAAU,EAAEE,GAAE,IAAK;MACvC,CAAC;MACDC,cAAc,EAAE,IAAI,CAACf,OAAO,CAACgB,MAAK,IAAK,QAAQ;MAC/CC,UAAU,EAAE,QAAO,CAAE;IACvB;EACF,CAAC;EAEDC,OAAO,EAAE;IACPC,YAAYA,CAAA,EAAG;MACb,IAAI,CAACC,KAAK,CAAC,gBAAgB,EAAE;QAC3BR,UAAU,EAAE,IAAI,CAACA,UAAU;QAC3BI,MAAM,EAAE,IAAI,CAACD;MACf,CAAC;MACD,IAAI,CAACJ,YAAW,GAAI,KAAI;IAC1B,CAAC;IAEDU,eAAeA,CAAA,EAAG;MAChB,IAAI,CAACD,KAAK,CAAC,aAAa,EAAE,IAAI,CAACH,UAAU,CAAC;IAC5C,CAAC;IAEDK,KAAKA,CAAA,EAAG;MACN,IAAI,CAACV,UAAS,GAAI;QAAEC,GAAG,EAAE,EAAE;QAAEC,GAAG,EAAE;MAAG,CAAC;MACtC,IAAI,CAACC,cAAa,GAAI,QAAQ;MAC9B,IAAI,CAACE,UAAS,GAAI,QAAQ;MAC1B,IAAI,CAACG,KAAK,CAAC,OAAO,CAAC;IACrB;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}