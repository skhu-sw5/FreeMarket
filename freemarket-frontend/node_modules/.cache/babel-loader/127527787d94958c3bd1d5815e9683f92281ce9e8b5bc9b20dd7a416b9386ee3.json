{"ast":null,"code":"export default {\n  name: 'MyProductCard',\n  props: {\n    product: {\n      type: Object,\n      required: true\n    },\n    stats: {\n      type: Object,\n      default: () => ({\n        viewCount: 0,\n        wishlistCount: 0\n      })\n    }\n  },\n  emits: ['edit', 'delete', 'click', 'refresh'],\n  data() {\n    return {\n      baseUrl: ''\n    };\n  },\n  created() {\n    // 항상 전체 URL 사용\n    this.baseUrl = 'https://freemarket.duckdns.org';\n  },\n  computed: {\n    isActive() {\n      return this.product.status === 'ACTIVE' || this.product.status === '판매중';\n    },\n    isSoldOut() {\n      return this.product.status === 'SOLD_OUT' || this.product.status === '판매완료';\n    },\n    productImage() {\n      // 이미지 URL을 가져오는 로직\n      console.log('상품 이미지 정보:', {\n        thumbnailUrl: this.product.thumbnailUrl,\n        imageUrls: this.product.imageUrls\n      });\n\n      // 1. thumbnailUrl이 있으면 사용\n      if (this.product.thumbnailUrl) {\n        return this.product.thumbnailUrl;\n      }\n      // 2. imageUrls 배열이 있고 첫 번째 이미지가 있으면 사용\n      else if (this.product.imageUrls && this.product.imageUrls.length > 0) {\n        return this.product.imageUrls[0];\n      }\n      // 이미지가 없는 경우\n      return null;\n    }\n  },\n  methods: {\n    formatPrice(price) {\n      return new Intl.NumberFormat('ko-KR').format(price);\n    },\n    formatDate(dateString) {\n      if (!dateString) return '';\n      const date = new Date(dateString);\n      return date.toLocaleDateString('ko-KR', {\n        year: 'numeric',\n        month: 'short',\n        day: 'numeric'\n      });\n    },\n    getImageUrl(url) {\n      if (!url) {\n        // 미리 만들어진 placeholder 이미지 사용\n        return 'data:image/svg+xml,%3Csvg width=\"300\" height=\"200\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Crect width=\"100%25\" height=\"100%25\" fill=\"%23f3f4f6\"/%3E%3Ctext x=\"50%25\" y=\"50%25\" text-anchor=\"middle\" dy=\".3em\" fill=\"%239ca3af\" font-family=\"Arial, sans-serif\" font-size=\"14\"%3ENo Image%3C/text%3E%3C/svg%3E';\n      }\n\n      // 이미 전체 URL인 경우 그대로 반환\n      if (url.startsWith('http://') || url.startsWith('https://')) {\n        return url;\n      }\n\n      // 상대 경로인 경우 baseUrl 추가\n      return `${this.baseUrl}${url}`;\n    },\n    getStatusClass(status) {\n      const statusClasses = {\n        '판매중': 'bg-green-100 text-green-800',\n        'ACTIVE': 'bg-green-100 text-green-800',\n        '품절': 'bg-red-100 text-red-800',\n        'SOLD_OUT': 'bg-red-100 text-red-800',\n        '판매완료': 'bg-blue-100 text-blue-800',\n        '판매중지': 'bg-gray-100 text-gray-800',\n        'INACTIVE': 'bg-gray-100 text-gray-800',\n        'DISCONTINUED': 'bg-gray-100 text-gray-800'\n      };\n      return statusClasses[status] || 'bg-gray-100 text-gray-800';\n    },\n    goToProduct() {\n      this.$emit('click', this.product.id);\n    },\n    editProduct() {\n      this.$emit('edit', this.product.id);\n    },\n    confirmDelete() {\n      if (confirm(`'${this.product.name}' 상품을 정말로 삭제하시겠습니까?\\n\\n이 작업은 되돌릴 수 없습니다.`)) {\n        this.$emit('delete', this.product.id);\n      }\n    },\n    // 판매 완료 처리 메서드\n    async markAsSold() {\n      try {\n        // 구매자 ID 입력 받기\n        const buyerId = prompt('구매자 ID를 입력해주세요:', '');\n        if (!buyerId) {\n          return; // 취소 버튼 누르거나 입력하지 않은 경우\n        }\n        if (isNaN(buyerId)) {\n          alert('구매자 ID는 숫자만 입력해주세요.');\n          return;\n        }\n\n        // 토큰 가져오기\n        const token = this.$store.state.auth.token;\n        if (!token) {\n          alert('인증 토큰이 없습니다. 다시 로그인해주세요.');\n          return;\n        }\n\n        // API 호출\n        const response = await fetch(`/api/products/${this.product.id}/sold?buyerId=${buyerId}`, {\n          method: 'POST',\n          headers: {\n            'Authorization': `Bearer ${token}`,\n            'Content-Type': 'application/json'\n          }\n        });\n        if (!response.ok) {\n          throw new Error(`판매 완료 처리에 실패했습니다. (${response.status})`);\n        }\n        const result = await response.json();\n\n        // 토스트 메시지 표시\n        if (this.$toast) {\n          this.$toast.success('상품이 판매 완료 처리되었습니다.');\n        } else {\n          alert('상품이 판매 완료 처리되었습니다.');\n        }\n\n        // 목록 새로고침 이벤트 발생\n        this.$emit('refresh');\n      } catch (error) {\n        console.error('판매 완료 처리 오류:', error);\n        if (this.$toast) {\n          this.$toast.error(`판매 완료 처리 중 오류가 발생했습니다: ${error.message}`);\n        } else {\n          alert(`판매 완료 처리 중 오류가 발생했습니다: ${error.message}`);\n        }\n      }\n    },\n    // 판매 완료 취소 메서드\n    async cancelSold() {\n      try {\n        if (!confirm(`'${this.product.name}' 상품의 판매 완료를 취소하시겠습니까?`)) {\n          return;\n        }\n\n        // 토큰 가져오기\n        const token = this.$store.state.auth.token;\n        if (!token) {\n          alert('인증 토큰이 없습니다. 다시 로그인해주세요.');\n          return;\n        }\n\n        // API 호출\n        const response = await fetch(`/api/products/${this.product.id}/cancel-sold`, {\n          method: 'POST',\n          headers: {\n            'Authorization': `Bearer ${token}`,\n            'Content-Type': 'application/json'\n          }\n        });\n        if (!response.ok) {\n          throw new Error(`판매 완료 취소에 실패했습니다. (${response.status})`);\n        }\n        const result = await response.json();\n\n        // 토스트 메시지 표시\n        if (this.$toast) {\n          this.$toast.success('판매 완료가 취소되었습니다.');\n        } else {\n          alert('판매 완료가 취소되었습니다.');\n        }\n\n        // 목록 새로고침 이벤트 발생\n        this.$emit('refresh');\n      } catch (error) {\n        console.error('판매 완료 취소 오류:', error);\n        if (this.$toast) {\n          this.$toast.error(`판매 완료 취소 중 오류가 발생했습니다: ${error.message}`);\n        } else {\n          alert(`판매 완료 취소 중 오류가 발생했습니다: ${error.message}`);\n        }\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","props","product","type","Object","required","stats","default","viewCount","wishlistCount","emits","data","baseUrl","created","computed","isActive","status","isSoldOut","productImage","console","log","thumbnailUrl","imageUrls","length","methods","formatPrice","price","Intl","NumberFormat","format","formatDate","dateString","date","Date","toLocaleDateString","year","month","day","getImageUrl","url","startsWith","getStatusClass","statusClasses","goToProduct","$emit","id","editProduct","confirmDelete","confirm","markAsSold","buyerId","prompt","isNaN","alert","token","$store","state","auth","response","fetch","method","headers","ok","Error","result","json","$toast","success","error","message","cancelSold"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\components\\products\\MyProductCard.vue"],"sourcesContent":["<template>\r\n  <div class=\"bg-white rounded-lg shadow-sm overflow-hidden border hover:shadow-md transition-shadow duration-300\">\r\n    <!-- 상품 이미지 -->\r\n    <div class=\"relative aspect-square overflow-hidden bg-gray-100\">\r\n      <img \r\n        v-if=\"productImage\" \r\n        :src=\"getImageUrl(productImage)\" \r\n        :alt=\"product.name\"\r\n        class=\"w-full h-full object-cover cursor-pointer hover:scale-105 transition-transform duration-300\"\r\n        @click=\"goToProduct\"\r\n      />\r\n      <div \r\n        v-else \r\n        class=\"w-full h-full flex items-center justify-center text-gray-400 cursor-pointer\"\r\n        @click=\"goToProduct\"\r\n      >\r\n        <i class=\"fas fa-image text-4xl\"></i>\r\n      </div>\r\n      \r\n      <!-- 상품 상태 배지 -->\r\n      <div class=\"absolute top-2 left-2\">\r\n        <span \r\n          class=\"px-2 py-1 text-xs font-medium rounded-full\"\r\n          :class=\"getStatusClass(product.status)\"\r\n        >\r\n          {{ product.status }}\r\n        </span>\r\n      </div>\r\n      \r\n      <!-- 관리 버튼들 -->\r\n      <div class=\"absolute top-2 right-2 flex space-x-1\">\r\n        <button\r\n          @click.stop=\"editProduct\"\r\n          class=\"p-2 bg-blue-500 text-white rounded-full hover:bg-blue-600 transition-colors\"\r\n          title=\"상품 수정\"\r\n        >\r\n          <i class=\"fas fa-edit text-sm\"></i>\r\n        </button>\r\n        <button\r\n          @click.stop=\"confirmDelete\"\r\n          class=\"p-2 bg-red-500 text-white rounded-full hover:bg-red-600 transition-colors\"\r\n          title=\"상품 삭제\"\r\n        >\r\n          <i class=\"fas fa-trash-alt text-sm\"></i>\r\n        </button>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- 상품 정보 -->\r\n    <div class=\"p-4\">\r\n      <h3 \r\n        class=\"font-medium text-gray-900 mb-2 line-clamp-2 cursor-pointer hover:text-blue-600 transition-colors\"\r\n        @click=\"goToProduct\"\r\n      >\r\n        {{ product.name }}\r\n      </h3>\r\n      \r\n      <div class=\"flex justify-between items-center mb-3\">\r\n        <span class=\"text-lg font-bold text-blue-600\">\r\n          {{ formatPrice(product.price) }}원\r\n        </span>\r\n        <span class=\"text-sm text-gray-500\">\r\n          재고 {{ product.stock || 0 }}개\r\n        </span>\r\n      </div>\r\n      \r\n      <div class=\"flex items-center justify-between text-sm text-gray-500\">\r\n        <span>{{ product.category }}</span>\r\n        <div class=\"flex items-center space-x-3\">\r\n          <span class=\"flex items-center\">\r\n            <i class=\"far fa-eye mr-1\"></i>\r\n            {{ stats?.viewCount || 0 }}\r\n          </span>\r\n          <span class=\"flex items-center\">\r\n            <i class=\"far fa-heart mr-1\"></i>\r\n            {{ stats?.wishlistCount || 0 }}\r\n          </span>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- 판매 완료 정보 (있는 경우) -->\r\n      <div v-if=\"product.buyerName || product.soldDate\" class=\"mt-3 pt-3 border-t text-sm text-gray-600\">\r\n        <div v-if=\"product.buyerName\" class=\"flex justify-between\">\r\n          <span>구매자:</span>\r\n          <span class=\"font-medium\">{{ product.buyerName }}</span>\r\n        </div>\r\n        <div v-if=\"product.soldDate\" class=\"flex justify-between mt-1\">\r\n          <span>판매일:</span>\r\n          <span>{{ formatDate(product.soldDate) }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- 등록일 -->\r\n      <div class=\"mt-3 text-xs text-gray-400\">\r\n        등록일: {{ formatDate(product.createdDate) }}\r\n      </div>\r\n      \r\n      <!-- 상품 관리 버튼들 (하단) -->\r\n      <div class=\"mt-4 grid grid-cols-2 gap-2\">\r\n        <button\r\n          @click=\"editProduct\"\r\n          class=\"px-3 py-2 bg-blue-500 text-white text-sm rounded font-medium hover:bg-blue-600 transition-colors flex items-center justify-center space-x-1\"\r\n        >\r\n          <i class=\"fas fa-edit\"></i>\r\n          <span>수정</span>\r\n        </button>\r\n        <button\r\n          @click=\"confirmDelete\"\r\n          class=\"px-3 py-2 bg-red-500 text-white text-sm rounded font-medium hover:bg-red-600 transition-colors flex items-center justify-center space-x-1\"\r\n        >\r\n          <i class=\"fas fa-trash-alt\"></i>\r\n          <span>삭제</span>\r\n        </button>\r\n      </div>\r\n      \r\n      <!-- 판매 완료 처리 및 취소 버튼 -->\r\n      <div class=\"mt-2\">\r\n        <!-- 판매중인 상품에 대한 판매 완료 처리 버튼 -->\r\n        <button \r\n          v-if=\"isActive\"\r\n          @click=\"markAsSold\"\r\n          class=\"w-full px-3 py-2 bg-green-600 text-white text-sm rounded font-medium hover:bg-green-700 transition-colors flex items-center justify-center space-x-1\"\r\n        >\r\n          <i class=\"fas fa-check-circle\"></i>\r\n          <span>판매 완료 처리</span>\r\n        </button>\r\n        \r\n        <!-- 판매완료된 상품에 대한 판매 취소 버튼 -->\r\n        <button \r\n          v-if=\"isSoldOut\"\r\n          @click=\"cancelSold\"\r\n          class=\"w-full px-3 py-2 bg-yellow-500 text-white text-sm rounded font-medium hover:bg-yellow-600 transition-colors flex items-center justify-center space-x-1\"\r\n        >\r\n          <i class=\"fas fa-undo\"></i>\r\n          <span>판매 완료 취소</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'MyProductCard',\r\n  \r\n  props: {\r\n    product: {\r\n      type: Object,\r\n      required: true\r\n    },\r\n    stats: {\r\n      type: Object,\r\n      default: () => ({\r\n        viewCount: 0,\r\n        wishlistCount: 0\r\n      })\r\n    }\r\n  },\r\n  \r\n  emits: ['edit', 'delete', 'click', 'refresh'],\r\n  \r\n  data() {\r\n    return {\r\n      baseUrl: ''\r\n    }\r\n  },\r\n  \r\n  created() {\r\n    // 항상 전체 URL 사용\r\n    this.baseUrl = 'https://freemarket.duckdns.org';\r\n  },\r\n  \r\n  computed: {\r\n    isActive() {\r\n      return this.product.status === 'ACTIVE' || this.product.status === '판매중'\r\n    },\r\n    \r\n    isSoldOut() {\r\n      return this.product.status === 'SOLD_OUT' || this.product.status === '판매완료'\r\n    },\r\n    \r\n    productImage() {\r\n      // 이미지 URL을 가져오는 로직\r\n      console.log('상품 이미지 정보:', { \r\n        thumbnailUrl: this.product.thumbnailUrl, \r\n        imageUrls: this.product.imageUrls\r\n      });\r\n      \r\n      // 1. thumbnailUrl이 있으면 사용\r\n      if (this.product.thumbnailUrl) {\r\n        return this.product.thumbnailUrl;\r\n      }\r\n      // 2. imageUrls 배열이 있고 첫 번째 이미지가 있으면 사용\r\n      else if (this.product.imageUrls && this.product.imageUrls.length > 0) {\r\n        return this.product.imageUrls[0];\r\n      }\r\n      // 이미지가 없는 경우\r\n      return null;\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    formatPrice(price) {\r\n      return new Intl.NumberFormat('ko-KR').format(price)\r\n    },\r\n    \r\n    formatDate(dateString) {\r\n      if (!dateString) return ''\r\n      const date = new Date(dateString)\r\n      return date.toLocaleDateString('ko-KR', {\r\n        year: 'numeric',\r\n        month: 'short',\r\n        day: 'numeric'\r\n      })\r\n    },\r\n    \r\n    getImageUrl(url) {\r\n      if (!url) {\r\n        // 미리 만들어진 placeholder 이미지 사용\r\n        return 'data:image/svg+xml,%3Csvg width=\"300\" height=\"200\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Crect width=\"100%25\" height=\"100%25\" fill=\"%23f3f4f6\"/%3E%3Ctext x=\"50%25\" y=\"50%25\" text-anchor=\"middle\" dy=\".3em\" fill=\"%239ca3af\" font-family=\"Arial, sans-serif\" font-size=\"14\"%3ENo Image%3C/text%3E%3C/svg%3E';\r\n      }\r\n      \r\n      // 이미 전체 URL인 경우 그대로 반환\r\n      if (url.startsWith('http://') || url.startsWith('https://')) {\r\n        return url;\r\n      }\r\n      \r\n      // 상대 경로인 경우 baseUrl 추가\r\n      return `${this.baseUrl}${url}`;\r\n    },\r\n    \r\n    getStatusClass(status) {\r\n      const statusClasses = {\r\n        '판매중': 'bg-green-100 text-green-800',\r\n        'ACTIVE': 'bg-green-100 text-green-800',\r\n        '품절': 'bg-red-100 text-red-800',\r\n        'SOLD_OUT': 'bg-red-100 text-red-800',\r\n        '판매완료': 'bg-blue-100 text-blue-800',\r\n        '판매중지': 'bg-gray-100 text-gray-800',\r\n        'INACTIVE': 'bg-gray-100 text-gray-800',\r\n        'DISCONTINUED': 'bg-gray-100 text-gray-800'\r\n      }\r\n      return statusClasses[status] || 'bg-gray-100 text-gray-800'\r\n    },\r\n    \r\n    goToProduct() {\r\n      this.$emit('click', this.product.id)\r\n    },\r\n    \r\n    editProduct() {\r\n      this.$emit('edit', this.product.id)\r\n    },\r\n    \r\n    confirmDelete() {\r\n      if (confirm(`'${this.product.name}' 상품을 정말로 삭제하시겠습니까?\\n\\n이 작업은 되돌릴 수 없습니다.`)) {\r\n        this.$emit('delete', this.product.id)\r\n      }\r\n    },\r\n    \r\n    // 판매 완료 처리 메서드\r\n    async markAsSold() {\r\n      try {\r\n        // 구매자 ID 입력 받기\r\n        const buyerId = prompt('구매자 ID를 입력해주세요:', '')\r\n        \r\n        if (!buyerId) {\r\n          return // 취소 버튼 누르거나 입력하지 않은 경우\r\n        }\r\n        \r\n        if (isNaN(buyerId)) {\r\n          alert('구매자 ID는 숫자만 입력해주세요.')\r\n          return\r\n        }\r\n        \r\n        // 토큰 가져오기\r\n        const token = this.$store.state.auth.token\r\n        if (!token) {\r\n          alert('인증 토큰이 없습니다. 다시 로그인해주세요.')\r\n          return\r\n        }\r\n        \r\n        // API 호출\r\n        const response = await fetch(`/api/products/${this.product.id}/sold?buyerId=${buyerId}`, {\r\n          method: 'POST',\r\n          headers: {\r\n            'Authorization': `Bearer ${token}`,\r\n            'Content-Type': 'application/json'\r\n          }\r\n        })\r\n        \r\n        if (!response.ok) {\r\n          throw new Error(`판매 완료 처리에 실패했습니다. (${response.status})`)\r\n        }\r\n        \r\n        const result = await response.json()\r\n        \r\n        // 토스트 메시지 표시\r\n        if (this.$toast) {\r\n          this.$toast.success('상품이 판매 완료 처리되었습니다.')\r\n        } else {\r\n          alert('상품이 판매 완료 처리되었습니다.')\r\n        }\r\n        \r\n        // 목록 새로고침 이벤트 발생\r\n        this.$emit('refresh')\r\n      } catch (error) {\r\n        console.error('판매 완료 처리 오류:', error)\r\n        if (this.$toast) {\r\n          this.$toast.error(`판매 완료 처리 중 오류가 발생했습니다: ${error.message}`)\r\n        } else {\r\n          alert(`판매 완료 처리 중 오류가 발생했습니다: ${error.message}`)\r\n        }\r\n      }\r\n    },\r\n    \r\n    // 판매 완료 취소 메서드\r\n    async cancelSold() {\r\n      try {\r\n        if (!confirm(`'${this.product.name}' 상품의 판매 완료를 취소하시겠습니까?`)) {\r\n          return\r\n        }\r\n        \r\n        // 토큰 가져오기\r\n        const token = this.$store.state.auth.token\r\n        if (!token) {\r\n          alert('인증 토큰이 없습니다. 다시 로그인해주세요.')\r\n          return\r\n        }\r\n        \r\n        // API 호출\r\n        const response = await fetch(`/api/products/${this.product.id}/cancel-sold`, {\r\n          method: 'POST',\r\n          headers: {\r\n            'Authorization': `Bearer ${token}`,\r\n            'Content-Type': 'application/json'\r\n          }\r\n        })\r\n        \r\n        if (!response.ok) {\r\n          throw new Error(`판매 완료 취소에 실패했습니다. (${response.status})`)\r\n        }\r\n        \r\n        const result = await response.json()\r\n        \r\n        // 토스트 메시지 표시\r\n        if (this.$toast) {\r\n          this.$toast.success('판매 완료가 취소되었습니다.')\r\n        } else {\r\n          alert('판매 완료가 취소되었습니다.')\r\n        }\r\n        \r\n        // 목록 새로고침 이벤트 발생\r\n        this.$emit('refresh')\r\n      } catch (error) {\r\n        console.error('판매 완료 취소 오류:', error)\r\n        if (this.$toast) {\r\n          this.$toast.error(`판매 완료 취소 중 오류가 발생했습니다: ${error.message}`)\r\n        } else {\r\n          alert(`판매 완료 취소 중 오류가 발생했습니다: ${error.message}`)\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.line-clamp-2 {\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.aspect-square {\r\n  aspect-ratio: 1 / 1;\r\n}\r\n</style>\r\n"],"mappings":"AA8IA,eAAe;EACbA,IAAI,EAAE,eAAe;EAErBC,KAAK,EAAE;IACLC,OAAO,EAAE;MACPC,IAAI,EAAEC,MAAM;MACZC,QAAQ,EAAE;IACZ,CAAC;IACDC,KAAK,EAAE;MACLH,IAAI,EAAEC,MAAM;MACZG,OAAO,EAAEA,CAAA,MAAO;QACdC,SAAS,EAAE,CAAC;QACZC,aAAa,EAAE;MACjB,CAAC;IACH;EACF,CAAC;EAEDC,KAAK,EAAE,CAAC,MAAM,EAAE,QAAQ,EAAE,OAAO,EAAE,SAAS,CAAC;EAE7CC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE;IACX;EACF,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR;IACA,IAAI,CAACD,OAAM,GAAI,gCAAgC;EACjD,CAAC;EAEDE,QAAQ,EAAE;IACRC,QAAQA,CAAA,EAAG;MACT,OAAO,IAAI,CAACb,OAAO,CAACc,MAAK,KAAM,QAAO,IAAK,IAAI,CAACd,OAAO,CAACc,MAAK,KAAM,KAAI;IACzE,CAAC;IAEDC,SAASA,CAAA,EAAG;MACV,OAAO,IAAI,CAACf,OAAO,CAACc,MAAK,KAAM,UAAS,IAAK,IAAI,CAACd,OAAO,CAACc,MAAK,KAAM,MAAK;IAC5E,CAAC;IAEDE,YAAYA,CAAA,EAAG;MACb;MACAC,OAAO,CAACC,GAAG,CAAC,YAAY,EAAE;QACxBC,YAAY,EAAE,IAAI,CAACnB,OAAO,CAACmB,YAAY;QACvCC,SAAS,EAAE,IAAI,CAACpB,OAAO,CAACoB;MAC1B,CAAC,CAAC;;MAEF;MACA,IAAI,IAAI,CAACpB,OAAO,CAACmB,YAAY,EAAE;QAC7B,OAAO,IAAI,CAACnB,OAAO,CAACmB,YAAY;MAClC;MACA;MAAA,KACK,IAAI,IAAI,CAACnB,OAAO,CAACoB,SAAQ,IAAK,IAAI,CAACpB,OAAO,CAACoB,SAAS,CAACC,MAAK,GAAI,CAAC,EAAE;QACpE,OAAO,IAAI,CAACrB,OAAO,CAACoB,SAAS,C