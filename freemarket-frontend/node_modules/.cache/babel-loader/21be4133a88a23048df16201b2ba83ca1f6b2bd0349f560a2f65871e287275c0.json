x-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors\"\r\n              :disabled=\"loading\"\r\n            >\r\n              <span v-if=\"loading\">\r\n                <i class=\"fas fa-spinner fa-spin mr-2\"></i>처리 중...\r\n              </span>\r\n              <span v-else>비밀번호 재설정 링크 받기</span>\r\n            </button>\r\n          </div>\r\n          \r\n          <div class=\"text-center mt-4\">\r\n            <router-link to=\"/login\" class=\"text-sm text-blue-600 hover:text-blue-800\">\r\n              로그인 페이지로 돌아가기\r\n            </router-link>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n    \r\n    <AppFooter />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AppHeader from '@/components/common/AppHeader.vue'\r\nimport AppFooter from '@/components/common/AppFooter.vue'\r\n\r\nexport default {\r\n  name: 'PasswordResetRequest',\r\n  \r\n  components: {\r\n    AppHeader,\r\n    AppFooter\r\n  },\r\n  \r\n  data() {\r\n    return {\r\n      email: '',\r\n      errors: {},\r\n      loading: false,\r\n      submitted: false\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    async submitRequest() {\r\n      this.errors = {}\r\n      this.loading = true\r\n      \r\n      try {\r\n        // 이메일 유효성 검사\r\n        if (!this.isValidEmail(this.email)) {\r\n          this.errors.email = '유효한 이메일 주소를 입력해주세요.'\r\n          return\r\n        }\r\n        \r\n        // API 요청\r\n        const response = await fetch('/api/auth/password/reset-request', {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Accept': 'application/json'\r\n          },\r\n          body: JSON.stringify({\r\n            email: this.email\r\n          })\r\n        })\r\n        \r\n        if (!response.ok) {\r\n          const errorData = await response.json()\r\n          if (response.status === 404) {\r\n            this.errors.email = '등록되지 않은 이메일 주소입니다.'\r\n          } else {\r\n            throw new Error(errorData.message || '서버 오류가 발생했습니다.')\r\n          }\r\n          return\r\n        }\r\n        \r\n        // 성공 처리\r\n        this.submitted = true\r\n        \r\n      } catch (error) {\r\n        console.error('비밀번호 재설정 요청 오류:', error)\r\n        this.$toast.error('비밀번호 재설정 요청에 실패했습니다.')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    \r\n    isValidEmail(email) {\r\n      const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/\r\n      return emailRegex.test(email)\r\n    }\r\n  }\r\n}\r\n</script> "],"mappings":"AA+DA,OAAOA,SAAQ,MAAO,mCAAkC;AACxD,OAAOC,SAAQ,MAAO,mCAAkC;AAExD,eAAe;EACbC,IAAI,EAAE,sBAAsB;EAE5BC,UAAU,EAAE;IACVH,SAAS;IACTC;EACF,CAAC;EAEDG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,MAAM,EAAE,CAAC,CAAC;MACVC,OAAO,EAAE,KAAK;MACdC,SAAS,EAAE;IACb;EACF,CAAC;EAEDC,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,IAAI,CAACJ,MAAK,GAAI,CAAC;MACf,IAAI,CAACC,OAAM,GAAI,IAAG;MAElB,IAAI;QACF;QACA,IAAI,CAAC,IAAI,CAACI,YAAY,CAAC,IAAI,CAACN,KAAK,CAAC,EAAE;UAClC,IAAI,CAACC,MAAM,CAACD,KAAI,GAAI,qBAAoB;UACxC;QACF;;QAEA;QACA,MAAMO,QAAO,GAAI,MAAMC,KAAK,CAAC,kCAAkC,EAAE;UAC/DC,MAAM,EAAE,MAAM;UACdC,OAAO,EAAE;YACP,cAAc,EAAE,kBAAkB;YAClC,QAAQ,EAAE;UACZ,CAAC;UACDC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAAC;YACnBb,KAAK,EAAE,IAAI,CAACA;UACd,CAAC;QACH,CAAC;QAED,IAAI,CAACO,QAAQ,CAACO,EAAE,EAAE;UAChB,MAAMC,SAAQ,GAAI,MAAMR,QAAQ,CAACS,IAAI,CAAC;UACtC,IAAIT,QAAQ,CAACU,MAAK,KAAM,GAAG,EAAE;YAC3B,IAAI,CAAChB,MAAM,CAACD,KAAI,GAAI,oBAAmB;UACzC,OAAO;YACL,MAAM,IAAIkB,KAAK,CAACH,SAAS,CAACI,OAAM,IAAK,gBAAgB;UACvD;UACA;QACF;;QAEA;QACA,IAAI,CAAChB,SAAQ,GAAI,IAAG;MAEtB,EAAE,OAAOiB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,iBAAiB,EAAEA,KAAK;QACtC,IAAI,CAACE,MAAM,CAACF,KAAK,CAAC,sBAAsB;MAC1C,UAAU;QACR,IAAI,CAAClB,OAAM,GAAI,KAAI;MACrB;IACF,CAAC;IAEDI,YAAYA,CAACN,KAAK,EAAE;MAClB,MAAMuB,UAAS,GAAI,4BAA2B;MAC9C,OAAOA,UAAU,CAACC,IAAI,CAACxB,KAAK;IAC9B;EACF;AACF","ignoreList":[]},"metadata":{},"source