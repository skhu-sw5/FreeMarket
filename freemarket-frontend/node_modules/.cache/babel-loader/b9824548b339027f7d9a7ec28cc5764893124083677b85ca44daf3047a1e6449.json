{"ast":null,"code":"import AppHeader from '@/components/common/AppHeader.vue';\nimport AppFooter from '@/components/common/AppFooter.vue';\nexport default {\n  name: 'PasswordReset',\n  components: {\n    AppHeader,\n    AppFooter\n  },\n  data() {\n    return {\n      token: '',\n      password: '',\n      passwordConfirm: '',\n      errors: {},\n      loading: false,\n      resetCompleted: false,\n      invalidToken: false\n    };\n  },\n  created() {\n    // URL에서 토큰 추출\n    this.token = this.$route.query.token;\n\n    // 토큰이 없으면 유효하지 않은 접근으로 간주\n    if (!this.token) {\n      this.invalidToken = true;\n    }\n  },\n  methods: {\n    async resetPassword() {\n      this.errors = {};\n\n      // 비밀번호 유효성 검사\n      if (this.password.length < 8) {\n        this.errors.password = '비밀번호는 8자 이상이어야 합니다.';\n        return;\n      }\n      if (this.password !== this.passwordConfirm) {\n        this.errors.passwordConfirm = '비밀번호가 일치하지 않습니다.';\n        return;\n      }\n      this.loading = true;\n      try {\n        const response = await fetch('/api/auth/password/reset', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'Accept': 'application/json'\n          },\n          body: JSON.stringify({\n            token: this.token,\n            newPassword: this.password\n          })\n        });\n        if (!response.ok) {\n          const errorData = await response.json();\n          if (response.status === 400 || response.status === 404) {\n            this.invalidToken = true;\n          } else {\n            throw new Error(errorData.message || '서버 오류가 발생했습니다.');\n          }\n          return;\n        }\n\n        // 성공 처리\n        this.resetCompleted = true;\n      } catch (error) {\n        console.error('비밀번호 재설정 오류:', error);\n        this.$toast.error('비밀번호 재설정에 실패했습니다.');\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["AppHeader","AppFooter","name","components","data","token","password","passwordConfirm","errors","loading","resetCompleted","invalidToken","created","$route","query","methods","resetPassword","length","response","fetch","method","headers","body","JSON","stringify","newPassword","ok","errorData","json","status","Error","message","error","console","$toast"],"sources":["C:\\Users\\조대현\\Desktop\\FreeMarket\\freemarket-frontend\\src\\views\\auth\\PasswordReset.vue"],"sourcesContent":["<template>\r\n  <div class=\"min-h-screen flex flex-col bg-gray-50\">\r\n    <AppHeader />\r\n    \r\n    <div class=\"flex-grow flex items-center justify-center p-4\">\r\n      <div class=\"bg-white rounded-lg shadow-md p-8 w-full max-w-md\">\r\n        <h1 class=\"text-2xl font-bold text-center mb-6\">비밀번호 재설정</h1>\r\n        \r\n        <div v-if=\"resetCompleted\" class=\"text-center bg-green-50 p-6 rounded-lg mb-4\">\r\n          <i class=\"fas fa-check-circle text-4xl text-green-500 mb-3\"></i>\r\n          <h2 class=\"text-xl font-semibold mb-2\">비밀번호 재설정 완료</h2>\r\n          <p class=\"text-gray-600 mb-4\">\r\n            비밀번호가 성공적으로 변경되었습니다.\r\n            새 비밀번호로 로그인하세요.\r\n          </p>\r\n          <router-link \r\n            to=\"/login\" \r\n            class=\"inline-block py-2 px-4 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors\"\r\n          >\r\n            로그인 페이지로 이동\r\n          </router-link>\r\n        </div>\r\n        \r\n        <div v-else-if=\"invalidToken\" class=\"text-center bg-red-50 p-6 rounded-lg mb-4\">\r\n          <i class=\"fas fa-exclamation-triangle text-4xl text-red-500 mb-3\"></i>\r\n          <h2 class=\"text-xl font-semibold mb-2\">유효하지 않은 링크</h2>\r\n          <p class=\"text-gray-600 mb-4\">\r\n            비밀번호 재설정 링크가 만료되었거나 유효하지 않습니다.\r\n            다시 비밀번호 재설정을 요청해주세요.\r\n          </p>\r\n          <router-link \r\n            to=\"/password-reset-request\" \r\n            class=\"inline-block py-2 px-4 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors\"\r\n          >\r\n            비밀번호 찾기\r\n          </router-link>\r\n        </div>\r\n        \r\n        <form v-else @submit.prevent=\"resetPassword\" class=\"space-y-4\">\r\n          <div class=\"space-y-2\">\r\n            <label for=\"password\" class=\"block text-sm font-medium text-gray-700\">새 비밀번호</label>\r\n            <input\r\n              id=\"password\"\r\n              v-model=\"password\"\r\n              type=\"password\"\r\n              required\r\n              autocomplete=\"new-password\"\r\n              class=\"w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\r\n              :class=\"{ 'border-red-500': errors.password }\"\r\n              placeholder=\"새로운 비밀번호를 입력하세요\"\r\n            />\r\n            <p v-if=\"errors.password\" class=\"text-red-500 text-sm\">{{ errors.password }}</p>\r\n          </div>\r\n          \r\n          <div class=\"space-y-2\">\r\n            <label for=\"passwordConfirm\" class=\"block text-sm font-medium text-gray-700\">비밀번호 확인</label>\r\n            <input\r\n              id=\"passwordConfirm\"\r\n              v-model=\"passwordConfirm\"\r\n              type=\"password\"\r\n              required\r\n              autocomplete=\"new-password\"\r\n              class=\"w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500\"\r\n              :class=\"{ 'border-red-500': errors.passwordConfirm }\"\r\n              placeholder=\"새로운 비밀번호를 다시 입력하세요\"\r\n            />\r\n            <p v-if=\"errors.passwordConfirm\" class=\"text-red-500 text-sm\">{{ errors.passwordConfirm }}</p>\r\n          </div>\r\n          \r\n          <div class=\"pt-2\">\r\n            <button\r\n              type=\"submit\"\r\n              class=\"w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors\"\r\n              :disabled=\"loading\"\r\n            >\r\n              <span v-if=\"loading\">\r\n                <i class=\"fas fa-spinner fa-spin mr-2\"></i>처리 중...\r\n              </span>\r\n              <span v-else>비밀번호 변경</span>\r\n            </button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n    \r\n    <AppFooter />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AppHeader from '@/components/common/AppHeader.vue'\r\nimport AppFooter from '@/components/common/AppFooter.vue'\r\n\r\nexport default {\r\n  name: 'PasswordReset',\r\n  \r\n  components: {\r\n    AppHeader,\r\n    AppFooter\r\n  },\r\n  \r\n  data() {\r\n    return {\r\n      token: '',\r\n      password: '',\r\n      passwordConfirm: '',\r\n      errors: {},\r\n      loading: false,\r\n      resetCompleted: false,\r\n      invalidToken: false\r\n    }\r\n  },\r\n  \r\n  created() {\r\n    // URL에서 토큰 추출\r\n    this.token = this.$route.query.token\r\n    \r\n    // 토큰이 없으면 유효하지 않은 접근으로 간주\r\n    if (!this.token) {\r\n      this.invalidToken = true\r\n    }\r\n  },\r\n  \r\n  methods: {\r\n    async resetPassword() {\r\n      this.errors = {}\r\n      \r\n      // 비밀번호 유효성 검사\r\n      if (this.password.length < 8) {\r\n        this.errors.password = '비밀번호는 8자 이상이어야 합니다.'\r\n        return\r\n      }\r\n      \r\n      if (this.password !== this.passwordConfirm) {\r\n        this.errors.passwordConfirm = '비밀번호가 일치하지 않습니다.'\r\n        return\r\n      }\r\n      \r\n      this.loading = true\r\n      \r\n      try {\r\n        const response = await fetch('/api/auth/password/reset', {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Accept': 'application/json'\r\n          },\r\n          body: JSON.stringify({\r\n            token: this.token,\r\n            newPassword: this.password\r\n          })\r\n        })\r\n        \r\n        if (!response.ok) {\r\n          const errorData = await response.json()\r\n          \r\n          if (response.status === 400 || response.status === 404) {\r\n            this.invalidToken = true\r\n          } else {\r\n            throw new Error(errorData.message || '서버 오류가 발생했습니다.')\r\n          }\r\n          return\r\n        }\r\n        \r\n        // 성공 처리\r\n        this.resetCompleted = true\r\n        \r\n      } catch (error) {\r\n        console.error('비밀번호 재설정 오류:', error)\r\n        this.$toast.error('비밀번호 재설정에 실패했습니다.')\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    }\r\n  }\r\n}\r\n</script> "],"mappings":"AA0FA,OAAOA,SAAQ,MAAO,mCAAkC;AACxD,OAAOC,SAAQ,MAAO,mCAAkC;AAExD,eAAe;EACbC,IAAI,EAAE,eAAe;EAErBC,UAAU,EAAE;IACVH,SAAS;IACTC;EACF,CAAC;EAEDG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,eAAe,EAAE,EAAE;MACnBC,MAAM,EAAE,CAAC,CAAC;MACVC,OAAO,EAAE,KAAK;MACdC,cAAc,EAAE,KAAK;MACrBC,YAAY,EAAE;IAChB;EACF,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR;IACA,IAAI,CAACP,KAAI,GAAI,IAAI,CAACQ,MAAM,CAACC,KAAK,CAACT,KAAI;;IAEnC;IACA,IAAI,CAAC,IAAI,CAACA,KAAK,EAAE;MACf,IAAI,CAACM,YAAW,GAAI,IAAG;IACzB;EACF,CAAC;EAEDI,OAAO,EAAE;IACP,MAAMC,aAAaA,CAAA,EAAG;MACpB,IAAI,CAACR,MAAK,GAAI,CAAC;;MAEf;MACA,IAAI,IAAI,CAACF,QAAQ,CAACW,MAAK,GAAI,CAAC,EAAE;QAC5B,IAAI,CAACT,MAAM,CAACF,QAAO,GAAI,qBAAoB;QAC3C;MACF;MAEA,IAAI,IAAI,CAACA,QAAO,KAAM,IAAI,CAACC,eAAe,EAAE;QAC1C,IAAI,CAACC,MAAM,CAACD,eAAc,GAAI,kBAAiB;QAC/C;MACF;MAEA,IAAI,CAACE,OAAM,GAAI,IAAG;MAElB,IAAI;QACF,MAAMS,QAAO,GAAI,MAAMC,KAAK,CAAC,0BAA0B,EAAE;UACvDC,MAAM,EAAE,MAAM;UACdC,OAAO,EAAE;YACP,cAAc,EAAE,kBAAkB;YAClC,QAAQ,EAAE;UACZ,CAAC;UACDC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAAC;YACnBnB,KAAK,EAAE,IAAI,CAACA,KAAK;YACjBoB,WAAW,EAAE,IAAI,CAACnB;UACpB,CAAC;QACH,CAAC;QAED,IAAI,CAACY,QAAQ,CAACQ,EAAE,EAAE;UAChB,MAAMC,SAAQ,GAAI,MAAMT,QAAQ,CAACU,IAAI,CAAC;UAEtC,IAAIV,QAAQ,CAACW,MAAK,KAAM,GAAE,IAAKX,QAAQ,CAACW,MAAK,KAAM,GAAG,EAAE;YACtD,IAAI,CAAClB,YAAW,GAAI,IAAG;UACzB,OAAO;YACL,MAAM,IAAImB,KAAK,CAACH,SAAS,CAACI,OAAM,IAAK,gBAAgB;UACvD;UACA;QACF;;QAEA;QACA,IAAI,CAACrB,cAAa,GAAI,IAAG;MAE3B,EAAE,OAAOsB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,cAAc,EAAEA,KAAK;QACnC,IAAI,CAACE,MAAM,CAACF,KAAK,CAAC,mBAAmB;MACvC,UAAU;QACR,IAAI,CAACvB,OAAM,GAAI,KAAI;MACrB;IACF;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}